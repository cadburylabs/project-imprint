.uir-websitecontentmanager-topbar { font-size: var(--nsn-uif-redwood-font-size-body-sm); font-weight: var(--nsn-uif-redwood-font-weight-semi-bold); }
.uir-websitecontentmanager-topbar > span { margin-left: var(--nsn-uif-redwood-spacing-6-x); cursor: pointer; }
.uir-websitecontentmanager-topbar img { display: none; }
.uir-webcontentmanager-showbar { display: inline-flex; gap: var(--nsn-uif-redwood-spacing-1-x); }
.uir-websitecontentmanager-topbar-new { display: none; }
.uir-setup-manager-navpane { flex-grow: 1; min-height: 0px; margin: 0 var(--nsn-uif-redwood-spacing-6-x) var(--nsn-uif-redwood-spacing-4-x) var(--nsn-uif-redwood-spacing-6-x); overflow: auto; }
.uir-bundlebuilder-arrangement .uir-field-arrangement--collapse-button { cursor: auto; }
