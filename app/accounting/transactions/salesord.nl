*, ::before, ::after { box-sizing: border-box; }
:focus { outline: 0px; }
.subtabblock { padding: 0px !important; }
input, select, textarea, button { font-family: inherit; }
table { font-size: inherit; }
html, body, div, dl, dt, dd, ul, ol, li, h1, h2, h3, h4, h5, h6, pre, form, fieldset, p, blockquote, th { margin: 0px; padding: 0px; }
