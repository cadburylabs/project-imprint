<span class="uir-field-input" data-fieldtype="summary" id="shippingaddress" data-helperbutton-count="0"><span id="hddn_shippingaddress_val"></span><input name="shippingaddress" id="hddn_shippingaddress" type="hidden" onchange="var shippingaddress = nlapiViewSubrecord('shippingaddress');
if (shippingaddress &amp;&amp; shippingaddress.getFieldValue('enable_subrecord_to_parent_synchronization') == 'T') 
{
    if (nlapiGetFieldValue('shipcountry') != shippingaddress.getFieldValue('country'))
    {
       nlapiSetFieldValue('shipcountry', shippingaddress.getFieldValue('country'));
    }
    if (nlapiGetFieldValue('shipstate') != shippingaddress.getFieldValue('state'))
    {
       nlapiSetFieldValue('shipstate', shippingaddress.getFieldValue('state'));
    }
    if (nlapiGetFieldValue('shipzip') != shippingaddress.getFieldValue('zip'))
    {
       nlapiSetFieldValue('shipzip', shippingaddress.getFieldValue('zip'));
    }
	if (nlapiGetFieldValue('shipoverride') != shippingaddress.getFieldValue('override'))
	{
       nlapiSetFieldValue('shipoverride', shippingaddress.getFieldValue('override'));
	}

	var updateShipAddress = (function() {
	var fieldChanged = false;
	var previousAddressFields = nlapiGetFieldValue('tax_affecting_address_fields_before_recalc');
	var lines = previousAddressFields.split(String.fromCharCode(4));
	if (lines)
	{
		for (var i = 0; i &lt; lines.length; i++)
		{
			var field = lines[i].split(String.fromCharCode(3));
			if (field[1] != shippingaddress.getFieldValue(field[0]))
			{
				fieldChanged = true;
			}
		}
	}
	else
	{
	    fieldChanged = true;
	}
	if (fieldChanged)
	{
		  var fieldsValue = 'city' + String.fromCharCode(3) + shippingaddress.getFieldValue('city') + String.fromCharCode(4) + 'state' + String.fromCharCode(3) + shippingaddress.getFieldValue('state') + String.fromCharCode(4) + 'zip' + String.fromCharCode(3) + shippingaddress.getFieldValue('zip') + String.fromCharCode(4) + 'country' + String.fromCharCode(3) + shippingaddress.getFieldValue('country');
   nlapiSetFieldValue('tax_affecting_address_fields_before_recalc', fieldsValue, false);

	}
	return fieldChanged;	})();;
	if (nlapiGetFieldValue('shippingaddress_text') != shippingaddress.getFieldValue('addrtext'))
	{
		nlapiSetFieldValue('shippingaddress_text', shippingaddress.getFieldValue('addrtext'));
		updateShipAddress = true;
	}
	nlapiSetFieldValue('shipaddresslist', '-2', false);

    if (updateShipAddress) {
	var slavingOrig = getSlavingAsync();
	try {
		setSlavingAsync(false);
nlapiSetFieldValue('shipaddress', shippingaddress.getFieldValue('addrtext'));
	} finally {
		setSlavingAsync(slavingOrig);
	}
	}
}" value="" class="nlsummary" style=""></span>
