<span class="uir-field-input" data-fieldtype="summary" id="billingaddress" data-helperbutton-count="0"><span id="hddn_billingaddress_val"></span><input name="billingaddress" id="hddn_billingaddress" type="hidden" onchange="var addressSummaryField = nlapiEditSubrecord('billingaddress');
if (addressSummaryField)
{
	if (nlapiGetFieldValue('billingaddress_text') != addressSummaryField.getFieldValue('addrtext'))
	{
		nlapiSetFieldValue('billingaddress_text', addressSummaryField.getFieldValue('addrtext'));
	}
	nlapiSetFieldValue('billaddresslist', '-2', false);
	var slavingOrig = getSlavingAsync();
	try {
		setSlavingAsync(false);
nlapiSetFieldValue('billaddress', addressSummaryField.getFieldValue('addrtext'));
	} finally {
		setSlavingAsync(slavingOrig);
	}
}" value="" class="nlsummary" style=""></span>
