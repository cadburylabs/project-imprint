" style="">
<input name="billingaddress_key" id="billingaddress_key" type="hidden" onchange="var addressSubrecord = nlapiEditSubrecord('billingaddress');if (addressSubrecord != null) {  if (typeof addressSubrecord.cancel === 'function') {	   addressSubrecord.cancel();  }  nlapiRemoveSubrecord('billingaddress');  if (typeof NLGetBusinessObject === 'function') {    var recordMgr = NLGetBusinessObject().getRecordManager('billingaddressaddress');
    if (recordMgr) {
      var segmentId;
      for (var id in recordMgr.dataSource.dataSet) {
        segmentId = id;
      }
      recordMgr.dataSource.clearData(segmentId);      if (recordMgr.dataSource.parent)      {        recordMgr.dataSource.parent.clearData(segmentId);
      }    }  }}" value="" style="">
