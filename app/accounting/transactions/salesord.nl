body[data-page-category="crm_history"] .portletTitleText > span[data-icon="ri_note"] { background-image: url("uiredwood/img/recordicon/note.svg"); }
body[data-page-category="crm_history"] .portletTitleText > span[data-icon="ri_email"] { background-image: url("uiredwood/img/recordicon/email.svg"); }
body[data-page-category="crm_history"] .portletTitleText > span[data-icon="ri_campaign"] { background-image: url("uiredwood/img/recordicon/campaign.svg"); }
body[data-page-category="crm_history"] .portletTitleText > span[data-icon="ri_case"] { background-image: url("uiredwood/img/recordicon/case.svg"); }
body[data-page-category="crm_history"] .portletBgColor > td > table { margin-top: var(--nsn-uif-redwood-spacing-2-x); background-color: var(--nsn-uif-redwood-color-light-neutral-20); border-radius: 8px; padding: 8px; }
body[data-page-category="hosted_center"] .portletHandle > td > table { width: 100%; }
body[data-page-category="hosted_center"] .uir-search-portlet-title { padding: var(--nsn-uif-redwood-size-2-xs); }
