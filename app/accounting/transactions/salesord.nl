.ir-feeback__footer { background-color: initial; flex: 1 1 auto; height: auto; justify-content: flex-end; padding: 0.2rem; }
.ir-pushRight { float: right; }
.ir-survey a { display: grid; flex-shrink: 0; height: 44px; margin: 0px; place-items: center; width: 44px; }
.ir-survey-answers::before { content: "Poor"; margin-right: 12px; }
.ir-survey-answers::after { content: "Excellent"; margin-left: 12px; }
.ir-feeback__footer__submit { background-color: rgb(49, 45, 42); border: 1px solid rgb(49, 45, 42); color: rgb(255, 255, 255); text-transform: capitalize; }
.ir-feeback__footer__submit:hover { background-color: rgb(58, 54, 50); }
.ir-feeback__footer__submit:active, .ir-feeback__footer__submit:focus { background-color: rgb(71, 66, 62); }
.ir-feeback__footer__skip { border: 1px solid rgba(22, 21, 19, 0.5); text-transform: capitalize; }
.ir-feeback__footer__skip:hover { background-color: rgba(22, 21, 19, 0.04); }
.ir-feeback__footer__skip:active, .ir-feeback__footer__skip:focus { background-color: rgba(22, 21, 19, 0.06); }
.ir-color-inherit { color: rgb(34, 34, 34); cursor: pointer; font-size: 16px; }
.ir-color-inherit:hover { opacity: 1; }
.ir-survey-answers { align-items: center; display: flex; gap: 12px; justify-content: center; }
.ir-survey-answer { background-color: rgb(237, 237, 237); border-radius: 4px; color: rgb(0, 0, 0); display: grid; font-size: 16px; font-weight: 600; height: 44px; margin: 8px; place-items: center; text-decoration: none; width: 44px; }
.ir-survey-answer:hover { background-color: rgb(226, 226, 226); }
.ir-survey-answer:active, .ir-survey-answer:focus { background-color: rgb(214, 214, 214); }
.ir-survey-question { color: rgb(0, 0, 0); font-size: 1em; font-weight: 500; line-height: 33px; margin-bottom: 10px; margin-top: 0px; text-align: center; }
.ir-float-container { overflow: hidden; }
body > .ir-survey__top { left: 0px; position: fixed; right: 0px; top: 0px; }
body > .ir-survey__bottom { bottom: 0px; left: 0px; position: fixed; right: 0px; }
