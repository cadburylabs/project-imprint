 uif1302" id="uif9056" data-widget="MenuItemContent" data-status="none"><span class="uif1195 uif1219 uif1221 uif1300" data-wrap="false" data-whitespace="false" data-type="default" id="uif12032" data-widget="Text" data-status="none">SuiteQL</span></div></div><svg class="uif1096 uif1099 uif992 uif995 uif1283" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg" data-icon="/assets/@uif-js/core/9.0.44/resources/img/RedwoodIcon.svg#ICO_CHEVRON_RIGHT" role="presentation" data-border-radius="square" id="uif12033" data-widget="Image" data-status="none" style="width: 20px; height: 20px;"><path fill-rule="evenodd" d="M8 17.65 9.739 19 16 12 9.739 5 8 6.35 13.054 12z"></path></svg></div></div></div>
