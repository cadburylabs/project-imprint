.uir-session-login .uir-session-login-description { font-size: var(--nsn-uif-redwood-font-size-body-md); margin-bottom: var(--nsn-uif-redwood-spacing-4-x); }
.uir-session-login .uir-session-login-button { position: relative; height: var(--nsn-uif-redwood-md-spacing-9-x); padding: 0 var(--nsn-uif-redwood-md-spacing-4-x); font-size: var(--nsn-uif-redwood-font-size-body-sm); font-weight: var(--nsn-uif-redwood-font-weight-semi-bold); border-radius: var(--nsn-uif-redwood-border-rounded-corners-mid); cursor: pointer; outline: inherit; border: 1px solid var(--nsn-uif-redwood-color-light-brand-120); background-color: var(--nsn-uif-redwood-color-light-brand-120); color: var(--nsn-uif-redwood-color-light-text-inverse); align-self: stretch; }
.uir-session-login .uir-session-login-button::before { content: ""; position: absolute; background-color: transparent; width: 100%; height: 100%; z-index: 1; top: 0px; left: 0px; border: 1px solid transparent; border-radius: var(--nsn-uif-redwood-border-rounded-corners-mid); }
