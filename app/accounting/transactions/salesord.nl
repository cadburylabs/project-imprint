.highcharts-no-data { display: none; }
.ns-dashboard-portlet-analytics-component { display: flex; flex-grow: 1; }
.ns-portlet-window-state-normal .ns-dashboard-portlet-analytics-component.ns-dashboard-portlet-analytics-component--short { height: 300px; }
.ns-portlet-window-state-normal .ns-dashboard-portlet-analytics-component.ns-dashboard-portlet-analytics-component--medium { height: 500px; }
.ns-portlet-window-state-normal .ns-dashboard-portlet-analytics-component.ns-dashboard-portlet-analytics-component--tall { height: 700px; }
.portlet-analytics-component-iframe { flex-grow: 1; border-width: medium; border-style: none; border-color: currentcolor; border-image: initial; height: 100%; }
.ns-analytics-portlet-wrapper.ns-portlet-window-state-maximalized { display: flex; flex-direction: column; }
.ns-analytics-portlet-wrapper.ns-portlet-window-state-maximalized .ns-portlet-body { display: flex; flex-grow: 1; }
.ns-analytics-portlet-wrapper.ns-portlet-window-state-maximalized .ns-portlet-content { display: flex; flex-grow: 1; }
