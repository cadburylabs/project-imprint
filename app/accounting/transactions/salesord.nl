html[data-scroll-behavior="app"] #body > #div__body, html[data-scroll-behavior="app"] #simplepage-body { display: flex; flex-direction: column; min-height: 0px; flex-grow: 1; }
a.dottedlink:not(.uir-no-link) { text-decoration: underline rgba(255, 255, 255, 0); transition: text-decoration-color var(--nsn-uif-redwood-animation-duration-medium); color: var(--nsn-uif-redwood-color-light-text-link); fill: var(--nsn-uif-redwood-color-light-text-link); }
a.dottedlink:not(.uir-no-link):hover { text-decoration-color: var(--nsn-uif-redwood-color-light-text-link); }
.uir-table { border-collapse: collapse; }
.uir-table thead th { font-weight: var(--nsn-uif-redwood-font-weight-semi-bold); text-align: left; }
.uir-table th, .uir-table td { border-bottom: 1px solid var(--nsn-uif-redwood-color-light-border-divider); padding: var(--nsn-uif-redwood-spacing-1-x) var(--nsn-uif-redwood-spacing-4-x); min-height: 28px; }
@media screen {
  body[data-page-background="auto"][data-page-category="dashboard"], body[data-page-background="auto"][data-page-category="list"], body[data-page-background="auto"][data-page-category="report"], body[data-page-background="auto"][data-page-category="wizard"] { background-color: var(--nsn-uif-redwood-color-light-neutral-10); }
  body[data-page-background="auto"] { background-color: white; }
  body[data-page-background="light"] { background-color: var(--nsn-uif-redwood-color-light-neutral-10); }
  .printonly { display: none; }
  .scrollarea { overflow: auto; }
}
@media print {
  html, body { height: auto !important; }
  .noprint { display: none !important; }
  .noprintvisibility { visibility: hidden; }
}
@keyframes spin { 
  100% { transform: rotate(360deg); }
}
@keyframes uir-spin-animation { 
  100% { transform: rotate(360deg); }
}
@keyframes pageSearchHighlight { 
  0% { outline-color: var(--nsn-uif-redwood-color-light-border-selected); }
  50% { outline-color: transparent; }
  100% { outline-color: var(--nsn-uif-redwood-color-light-border-selected); }
}
