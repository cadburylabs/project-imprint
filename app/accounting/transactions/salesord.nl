.uir-bundlebuilder-arrangement .uir-field-arrangement-header-simple { padding-bottom: var(--nsn-uif-redwood-spacing-1-x); }
.uir-bundlebuilder-inner-table { overflow: hidden auto; height: 500px; width: 275px; padding-top: var(--nsn-uif-redwood-spacing-2-x); border-top: 1px solid rgb(204, 204, 204); }
.uir-bundlebuilder-info-icon { display: inline-flex; width: var(--nsn-uif-redwood-spacing-6-x); height: var(--nsn-uif-redwood-spacing-6-x); background-image: url("uiredwood/icon/information.svg"); background-size: contain; }
.uir-bundlebuilder-summary-object-icon { display: inline-flex; align-items: flex-start; gap: var(--nsn-uif-redwood-spacing-1-x); }
.uir-bundlebuilder-summary-object-icon::before { content: ""; display: inline-flex; flex-shrink: 0; width: 20px; height: 20px; background-image: url("uiredwood/icon/application-suite.svg"); background-size: contain; }
.uir-bundlebuilder-summary-folder-icon { display: inline-flex; align-items: flex-start; gap: var(--nsn-uif-redwood-spacing-1-x); }
.uir-bundlebuilder-summary-folder-icon::before { content: ""; display: inline-flex; flex-shrink: 0; width: 20px; height: 20px; background-image: url("uiredwood/icon/folder-open.svg"); background-size: contain; }
.uir-bundlebuilder-object-box-icon { display: inline-flex; flex-shrink: 0; width: 20px; height: 20px; background-image: url("uiredwood/icon/box.svg"); background-size: contain; margin: 0 var(--nsn-uif-redwood-spacing-1-x); }
.uir-bundlebuilder-check-box { vertical-align: top; padding-top: 2px; }
.uir-bundlebuilder-content-item { display: inline-flex; align-items: flex-start; gap: var(--nsn-uif-redwood-spacing-1-x); font-style: italic; }
.uir-bundlebuilder-content-item::before { content: ""; display: inline-flex; flex-shrink: 0; width: 20px; height: 20px; background-image: url("uiredwood/icon/inventory-count.svg"); background-size: contain; }
.uir-bundlebuilder-content-infomessage { padding-left: var(--nsn-uif-redwood-spacing-1-x); }
.uir-bundlebuilder-arrow { display: inline-flex; width: var(--nsn-uif-redwood-spacing-8-x); height: var(--nsn-uif-redwood-spacing-8-x); background-image: url("uiredwood/icon/arrow-alt-right.svg"); background-size: contain; }
.uir-bundlebuilder-select-all { display: flex; align-items: center; gap: var(--nsn-uif-redwood-spacing-1-x); font-size: var(--nsn-uif-redwood-font-size-body-sm); font-weight: var(--nsn-uif-redwood-font-weight-regular); }
.uir-bundlebuilder-tree-field-linked-icon { display: inline-flex; flex-shrink: 0; width: 20px; height: 20px; background-image: url("uiredwood/icon/structure.svg"); background-size: contain; }
.uir-bundlebuilder-summary-box-checked-icon { display: inline-flex; flex-shrink: 0; width: 20px; height: 20px; background-image: url("uiredwood/icon/inventory-count.svg"); background-size: contain; }
.uir-profitability-configuration-fields .uir-tab-fields { padding: 0px; }
.uir-profitability-configuration-delete-icon { display: inline-flex; width: 20px; height: 20px; }
.uir-profitability-configuration-delete-icon[data-enabled="true"] { background-image: url("uiredwood/icon/trash.svg"); background-size: contain; }
.uir-profitability-configuration-delete-icon[data-enabled="false"] { background-color: var(--nsn-uif-redwood-color-light-neutral-60); mask-image: url("uiredwood/icon/trash.svg"); mask-size: contain; }
.uir-field-billing-warn { margin-bottom: var(--nsn-uif-redwood-spacing-2-x); }
.uir-fax-preferences-help { margin: var(--nsn-uif-redwood-spacing-4-x) var(--nsn-uif-redwood-spacing-6-x) 0 var(--nsn-uif-redwood-spacing-6-x); padding: var(--nsn-uif-redwood-spacing-3-x) var(--nsn-uif-redwood-spacing-8-x); background-color: var(--nsn-uif-redwood-color-light-surface-info-low); border-radius: var(--nsn-uif-redwood-border-rounded-corners); }
.uir-editor-group-container { border-bottom: 1px solid var(--nsn-uif-redwood-color-light-border-divider); }
.uir-editor-group { border-top-color: ; border-top-style: ; border-top-width: ; border-right-color: ; border-right-style: ; border-right-width: ; border-left-color: ; border-left-style: ; border-left-width: ; border-image-source: ; border-image-slice: ; border-image-width: ; border-image-outset: ; border-image-repeat: ; border-bottom: 0px; padding: 0 var(--nsn-uif-redwood-spacing-3-x) var(--nsn-uif-redwood-spacing-2-x) var(--nsn-uif-redwood-spacing-3-x); }
.uir-editor-group-title { font-weight: var(--nsn-uif-redwood-font-weight-semi-bold); padding-top: var(--nsn-uif-redwood-spacing-2-x); }
#uir-right-layout-editor { margin-left: 10px; }
#elements_layer { margin-top: 10px; }
.uir-goto-task-icon { width: 24px; height: 24px; }
.uir-icon-check { display: inline-flex; width: 20px; height: 20px; background-size: contain; background-image: url("uiredwood/img/list/check.svg"); }
.uir-icon-help { display: inline-flex; width: 20px; height: 20px; background-size: contain; background-image: url("uiredwood/img/list/help.svg"); }
.uir-icon-warning { display: inline-flex; width: 20px; height: 20px; background-size: contain; background-image: url("uiredwood/img/list/warning.svg"); }
.uir-icon-expand { display: inline-flex; width: 20px; height: 20px; background-size: contain; background-image: url("uiredwood/img/icon/expand.svg"); }
.uir-icon-collapse { display: inline-flex; width: 20px; height: 20px; background-size: contain; background-image: url("uiredwood/img/icon/collapse.svg"); }
.uir-icon-search { display: inline-flex; width: 20px; height: 20px; background-size: contain; background-image: url("uiredwood/img/icon/search.svg"); }
.uir-icon-lock { display: inline-flex; width: 20px; height: 20px; background-size: contain; background-image: url("uiredwood/img/icon/lock.svg"); }
.uir-icon-add { display: inline-flex; background-image: url("uiredwood/img/icon/add.svg"); height: 20px; width: 20px; background-position: center center; background-repeat: no-repeat; background-size: 16px 16px; }
.uir-icon-pencil { display: inline-flex; background-image: url("uiredwood/img/icon/edit.svg"); height: 20px; width: 20px; background-position: center center; background-repeat: no-repeat; background-size: 16px 16px; }
.uir-icon-open { display: inline-flex; background-image: url("uiredwood/img/icon/external-link.svg"); height: 20px; width: 20px; background-position: center center; background-repeat: no-repeat; background-size: 16px 16px; }
.uir-icon-close { display: inline-flex; width: 20px; height: 20px; background-size: contain; background-image: url("uiredwood/icon/close.svg"); }
.selector-filter-input { width: 180px; }
.selector-filter-container > .ddarrowSpan { display: none; }
.selector-popup { position: absolute; width: 300px; z-index: 1000; cursor: default; }
.selector-popup.above { bottom: -5px; left: -4px; }
.selector-popup.below { top: -5px; left: -4px; }
.selector-popup-fixedposition { width: 300px; }
.selector-popup-inner { border: 1px solid rgb(91, 113, 140); padding: 5px; height: 100%; background-color: rgb(252, 252, 252); }
.selector-popup h3 { font-size: 14px; font-weight: 600; padding-bottom: 3px; }
.selector-input-spacer { position: relative; background-color: rgb(252, 252, 252); }
.selector-input-spacer.bottom { bottom: 6px; left: 4px; height: 20px; }
.selector-input-spacer.top { top: 1px; height: 34px; }
.selector-options { overflow: auto; max-height: 300px; }
.selector-options h3 { padding: 7px 0px 4px; }
.selector-favourites { border-bottom: 1px dotted rgb(91, 113, 140); }
.selector-favourites, .selector-all { padding: 0px 0px 9px; }
.selector-filters { width: 100%; border-bottom: 1px dotted rgb(91, 113, 140); padding: 0px 0px 9px; table-layout: fixed; border-spacing: 4px; }
.selector-filter-button { border: 1px solid rgb(91, 113, 140); padding: 3px 4px; border-radius: 6px; font-size: 13px; background-color: rgb(240, 240, 240); cursor: pointer; }
.selector-filter-button:hover { background-color: rgb(163, 177, 193); }
.selector-filter-button.checked { background-color: rgb(96, 119, 153); }
.selector-favourites .selector-star { background-image: url("images/selectors/star.png"); }
.selector-favourites .selector-selected .selector-star, .selector-all .selector-item:hover .selector-star { background-image: url("images/selectors/star-white.png"); }
.selector-folder-closed div { display: none; }
.selector-folder-open h3 { background-image: url("images/selectors/fold-open.png"); background-position: 0px 57%; background-repeat: no-repeat; padding-left: 10px; cursor: pointer; }
.selector-folder-closed h3 { background-image: url("images/selectors/fold-closed.png"); background-position: 0px 57%; background-repeat: no-repeat; padding-left: 10px; cursor: pointer; }
.selector-folder-disabled h3 { padding-left: 10px; color: rgb(96, 96, 96); background-image: none !important; }
.selector-folder-disabled .selector-all, .selector-folder-disabled .selector-favourites { padding-bottom: 2px; }
.selector-star { background: center center no-repeat; width: 20px; display: inline-block; }
.selector-item { text-overflow: ellipsis; overflow: hidden; cursor: pointer; }
.selector-item, .selector-item * { font-size: 13px !important; }
.selector-item b { font-weight: bold !important; }
.selector-selected { background-color: rgb(96, 119, 153) !important; color: rgb(255, 255, 255); }
body[data-page-category="wizard"] .uir-form-header { background-color: transparent; }
.uir-rightpane-form { display: flex; flex-direction: column; flex-grow: 1; min-height: 0px; padding-bottom: 0px !important; }
.uir-rightpane-header { flex-shrink: 0; }
.uir-rightpane-main { display: flex; flex-direction: column; flex-grow: 1; min-height: 0px; }
.uir-rightpane-top { flex-shrink: 0; padding: 0 var(--nsn-uif-redwood-spacing-6-x); border-bottom: 1px solid var(--nsn-uif-redwood-color-light-border-divider); }
.uir-rightpane-north { flex-shrink: 0; padding: var(--nsn-uif-redwood-spacing-3-x) var(--nsn-uif-redwood-spacing-6-x); overflow: auto; }
.uir-rightpane-north .uir-field-wrapper { margin-top: 0px; margin-right: 0px; }
.uir-rightpane-north > table > tbody > tr { display: flex; align-items: flex-end; gap: var(--nsn-uif-redwood-spacing-4-x); }
.uir-rightpane-body { display: flex; flex-grow: 1; min-height: 0px; border-top: 1px solid var(--nsn-uif-redwood-color-light-border-divider); }
.uir-rightpane-nav { display: flex; border-right: 1px solid var(--nsn-uif-redwood-color-light-border-divider); }
.uir-rightpane-nav #div__nav { display: flex; flex-direction: column; flex-grow: 1; }
.uir-rightpane-content { display: flex; flex-direction: column; flex-grow: 1; min-width: 0px; }
.uir-rightpane-content-top { display: flex; flex-direction: column; position: relative; flex-grow: 1; min-height: 0px; overflow: auto; }
.uir-rightpane-content-top-inner { padding: var(--nsn-uif-redwood-spacing-6-x); }
.uir-rightpane-content-fill { display: flex; flex-direction: column; flex-grow: 1; min-height: 0px; }
.uir-rightpane-content-fill > iframe { flex-grow: 1; min-height: 0px; }
.uir-rightpane-content-bottom { flex-shrink: 0; }
.uir-rightpane-buttons { display: flex; justify-content: flex-end; padding: var(--nsn-uif-redwood-spacing-3-x) var(--nsn-uif-redwood-spacing-6-x); border-top: 1px solid var(--nsn-uif-redwood-color-light-border-divider); }
.uir-rightpane-buttons .uir-button-wrapper, .uir-rightpane-buttons .uir-multi-button-wrapper { padding-left: var(--nsn-uif-redwood-spacing-3-x); }
.uir-rightpane-section-title { flex-shrink: 0; font-size: var(--nsn-uif-redwood-font-size-body-md); font-weight: var(--nsn-uif-redwood-font-weight-bold); line-height: var(--nsn-uif-redwood-font-size-heading-sm); margin-bottom: var(--nsn-uif-redwood-spacing-4-x); }
.uir-rightpane-search-input { display: flex; border: 1px solid var(--nsn-uif-redwood-color-light-border-enabled); border-radius: 3px; background-color: var(--nsn-uif-redwood-color-light-neutral-0); height: 40px; margin: 0 var(--nsn-uif-redwood-spacing-6-x) var(--nsn-uif-redwood-spacing-4-x) var(--nsn-uif-redwood-spacing-6-x); padding: 0 var(--nsn-uif-redwood-spacing-4-x); gap: var(--nsn-uif-redwood-spacing-3-x); }
.uir-rightpane-search-input > input { flex-grow: 1; min-width: 0px; appearance: none; border-width: medium; border-style: none; border-color: currentcolor; border-image: initial; font-size: var(--nsn-uif-redwood-font-size-body-md); }
.uir-rightpane-search-input button { display: none !important; }
.uir-rightpane-search-input::before { content: ""; align-self: center; flex-shrink: 0; width: 20px; height: 20px; background-image: url("uiredwood/icon/search.svg"); background-size: contain; }
.uir-rightpane-search-input:focus-within { outline: 2px solid var(--nsn-uif-redwood-color-light-border-selected); outline-offset: -1px; }
.uir-rightpane-search-results { flex-grow: 1; min-height: 0px; overflow: auto; margin: 0 var(--nsn-uif-redwood-spacing-6-x) var(--nsn-uif-redwood-spacing-4-x) var(--nsn-uif-redwood-spacing-6-x); }
.uir-rightpane-dragger { background-image: url("images/assistant/grippy.gif"); background-position: right center; background-repeat: no-repeat; cursor: ew-resize; width: 5px; border-right: 1px solid var(--nsn-uif-redwood-color-light-border-divider); }
.uir-rightpane-drag-line { position: absolute; width: 3px; background-color: var(--nsn-uif-redwood-color-light-neutral-200); }
body[data-page-category="wizard"] #outerwrapper { display: flex; flex-direction: column; height: 100%; }
body[data-page-category="wizard"] #innerwrapper { display: flex; flex-direction: column; flex-grow: 1; min-height: 0px; }
.uir_assistant_leftpanel_header { display: flex; align-items: center; flex-shrink: 0; padding: var(--nsn-uif-redwood-spacing-3-x) var(--nsn-uif-redwood-spacing-6-x); }
.uir_assistant_leftpanel_header:not(:first-child) { border-top: 1px solid var(--nsn-uif-redwood-color-light-border-divider); }
.uir_assistant_leftpanel_header[onclick] { cursor: pointer; }
.uir_assistant_leftpanel_label, .uir_assistant_leftpanel_rightsidehtml { color: var(--nsn-uif-redwood-color-light-text-primary); font-size: var(--nsn-uif-redwood-font-size-body-sm); font-weight: var(--nsn-uif-redwood-font-weight-semi-bold); }
.uir_assistant_leftpanel_rightsidehtml { margin-left: auto; }
.uir-assistant-navpane { flex-grow: 1; min-height: 0px; margin: 0 var(--nsn-uif-redwood-spacing-6-x) var(--nsn-uif-redwood-spacing-4-x) var(--nsn-uif-redwood-spacing-6-x); overflow: auto; }
.uir-assistant-warning-message { display: inline-flex; align-items: center; }
.uir-assistant-warning-icon { display: inline-flex; width: var(--nsn-uif-redwood-spacing-6-x); height: var(--nsn-uif-redwood-spacing-6-x); margin-right: var(--nsn-uif-redwood-spacing-1-x); background-image: url("uiredwood/icon/warning.svg"); background-size: contain; }
.uir_assistant_steps_list { padding: 0px; margin: 0px; }
.uir_assistant_steps_list[data-numbered="false"] > .uir-assistant-step::before { content: ""; width: 20px; height: 20px; }
.uir_assistant_steps_list[data-numbered="false"] > .uir_assistant_step_complete::before { mask-image: url("uiredwood/icon/check.svg"); mask-size: contain; background-color: rgba(22, 21, 19, 0.4); }
.uir_assistant_steps_list[data-numbered="false"] > .uir_assistant_current_step_error::before { background-image: url("uiredwood/icon/close.svg"); background-size: contain; }
.uir_assistant_steps_list[data-numbered="true"] > .uir-assistant-step::before { content: ""; position: absolute; left: 27px; z-index: -1; }
.uir_assistant_steps_list[data-numbered="true"] > .uir-assistant-step:first-child:not(:last-child)::before { top: 50%; height: 50%; border-left: 2px solid rgba(49, 45, 42, 0.16); }
.uir_assistant_steps_list[data-numbered="true"] > .uir-assistant-step:last-child:not(:first-child)::before { top: 0px; height: 50%; border-left: 2px solid rgba(49, 45, 42, 0.16); }
.uir_assistant_steps_list[data-numbered="true"] > .uir-assistant-step:not(:first-child):not(:last-child)::before { top: 0px; height: 100%; border-left: 2px solid rgba(49, 45, 42, 0.16); }
.uir-assistant-step { position: relative; display: flex; align-items: center; gap: var(--nsn-uif-redwood-spacing-3-x); padding: 7px var(--nsn-uif-redwood-spacing-4-x); }
.uir_assistant_current_step, .uir_assistant_current_step_error { border-radius: var(--nsn-uif-redwood-border-rounded-corners); background-color: var(--nsn-uif-redwood-color-light-overlay-active); }
.uir_assistant_current_step > .uir_assistant_step_label, .uir_assistant_current_step_error > .uir_assistant_step_label, .ns-step-text.selected { color: var(--nsn-uif-redwood-color-light-neutral-200); }
.uir_assistant_current_step > .uir_assistant_step_number, .ns-step-circle.selected { color: var(--nsn-uif-redwood-color-light-neutral-0); background-color: var(--nsn-uif-redwood-color-light-neutral-200); border-color: var(--nsn-uif-redwood-color-light-neutral-200); }
.uir_assistant_current_step_error > .uir_assistant_step_number { color: var(--nsn-uif-redwood-color-light-neutral-0); background-color: var(--nsn-uif-redwood-color-light-surface-danger-strong); border-color: var(--nsn-uif-redwood-color-light-surface-danger-strong); }
.uir_assistant_step_complete > .uir_assistant_step_label, .uir_assistant_step_incomplete > .uir_assistant_step_label, .ns-step-text:not(.selected) { color: rgba(22, 21, 19, 0.4); }
.uir_assistant_step_complete > .uir_assistant_step_number { background-color: rgb(73, 118, 132); border-color: rgb(73, 118, 132); color: white; }
.uir_assistant_step_incomplete > .uir_assistant_step_number, .ns-step-circle:not(.selected) { background-color: var(--nsn-uif-redwood-color-light-neutral-10); border-color: rgba(22, 21, 19, 0.4); color: rgba(22, 21, 19, 0.4); }
.uir_assistant_step_number, .ns-step-circle { display: flex; align-items: center; justify-content: center; height: 24px; width: 24px; border-radius: 50%; border-width: 2px; border-style: solid; font-size: var(--nsn-uif-redwood-font-size-body-xs); font-weight: var(--nsn-uif-redwood-font-weight-bold); }
.uir_assistant_step_label, .ns-step-text { font-size: var(--nsn-uif-redwood-font-size-body-sm); font-weight: var(--nsn-uif-redwood-font-weight-semi-bold); }
.ns-steps-container { display: flex; align-items: flex-start; padding: var(--nsn-uif-redwood-spacing-2-x) 0; overflow-x: auto; }
.ns-step-block { position: relative; display: flex; flex-direction: column; align-items: center; gap: var(--nsn-uif-redwood-spacing-2-x); padding: var(--nsn-uif-redwood-spacing-3-x) var(--nsn-uif-redwood-spacing-4-x); }
.ns-step-block.selected { border-radius: var(--nsn-uif-redwood-border-rounded-corners); background-color: var(--nsn-uif-redwood-color-light-overlay-active); }
.ns-step-block::before { content: ""; position: absolute; top: 23px; z-index: -1; }
.ns-step-block:first-child:not(:last-child)::before { left: 50%; width: 50%; border-top: 3px solid rgba(49, 45, 42, 0.16); }
.ns-step-block:last-child:not(:first-child)::before { left: 0px; width: 50%; border-top: 3px solid rgba(49, 45, 42, 0.16); }
.ns-step-block:not(:first-child):not(:last-child)::before { left: 0px; width: 100%; border-top: 3px solid rgba(49, 45, 42, 0.16); }
.ns-step-circle, .ns-step-text { cursor: pointer; }
.uir-assistant-errorbar { display: flex; align-items: center; gap: var(--nsn-uif-redwood-spacing-2-x); padding: var(--nsn-uif-redwood-spacing-3-x); background-color: var(--nsn-uif-redwood-color-light-surface-danger-low); margin-bottom: var(--nsn-uif-redwood-spacing-2-x); border: 1px solid var(--nsn-uif-redwood-color-light-border-divider) !important; }
.uir-assistant-errorbar-icon { width: 20px; height: 20px; background-image: url("uiredwood/img/message/error.svg"); background-size: contain; }
.uir-fieldarrangement-fieldwraptable-outer { padding-right: var(--nsn-uif-redwood-spacing-6-x); }
.uir-assistant-file-name { display: inline-flex; align-items: center; gap: var(--nsn-uif-redwood-spacing-1-x); padding: var(--nsn-uif-redwood-spacing-1-x) var(--nsn-uif-redwood-spacing-6-x); }
.uir-assistant-file-name::before { display: inline-flex; flex-shrink: 0; width: 24px; height: 24px; }
.uir-assistant-file-name[data-error="false"]:not(:empty)::before { content: ""; background-image: url("uiredwood/icon/file-csv.svg"); background-size: contain; }
.uir-assistant-file-name[data-error="true"]:not(:empty) { color: var(--nsn-uif-redwood-color-light-text-danger); text-decoration: line-through; }
