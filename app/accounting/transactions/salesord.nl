#rptdataarea .rpthdline1, #rptdataarea .regheaderline1, #rptdataarea .regheaderline2 { font-size: var(--nsn-uif-redwood-font-size-body-sm); font-weight: var(--nsn-uif-redwood-font-weight-semi-bold); padding: 0 var(--nsn-uif-redwood-spacing-2-x) !important; }
