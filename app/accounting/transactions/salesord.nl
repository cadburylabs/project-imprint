body[data-page-category="crm_history"] .portletTitleText, body[data-page-category="crm_history"] .smallgraytextnolink { font-weight: var(--nsn-uif-redwood-font-weight-bold); }
body[data-page-category="crm_history"] .portletTitleText { display: flex; align-items: center; }
body[data-page-category="crm_history"] .portletTitleText > span { display: block; flex-shrink: 0; width: 20px; height: 20px; background-size: contain; margin-right: var(--nsn-uif-redwood-spacing-2-x); }
