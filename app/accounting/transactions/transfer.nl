function checkForMixedCurrency(mach,machCurField)
{
  var linecount = nlapiGetLineItemCount(mach);
  var machIsFxCurField = machCurField+'_fx';
  var trancurrency = nlapiGetFieldValue('currency');
  for (var i=1; i <= linecount; i++) {
  	var machCurFieldValue = getEncodedValue(mach,i,machCurField);
  	var machisFxCurFieldValue = getEncodedValue(mach,i,machIsFxCurField);
		if (machCurFieldValue && machCurFieldValue != trancurrency && machisFxCurFieldValue && machisFxCurFieldValue=='T') {
      alert('There are lines with foreign currency bank accounts that do not match the currency selected for this transaction.  This must be corrected prior to submitting the form.');
      return false;
    }
  }
return true;}
function validateCurrencyChange(mach,machCurField){
  var linecount = nlapiGetLineItemCount(mach);
  var trancurrency = nlapiGetFieldValue('currency');
  for (var i=1; i <= linecount; i++) {
      var allowableCurrencies = getEncodedValue(mach,i,machCurField).split(',');
    	 if ( allowableCurrencies == '' ) {continue;}
  	 var found = false;
      for (var j=0; j <= allowableCurrencies.length; j++) {
    		if ( allowableCurrencies[j] == trancurrency ) {found=true;break;}
    	 }
    	 if ( found == false){
      	var accounttype=nlapiGetLineItemValue(mach, 'accounttype', i)
      	var entitytype=nlapiGetLineItemValue(mach, 'entitytype', i)
      	if(accounttype=='AcctRec' && entitytype=='CustJob'){
      	    alert('You are trying to adjust an A/R account, but the selected currency is not available to one or more customers on this journal entry.   You must remove these customers before you change the transaction currency.');
      	}
      	else if(accounttype=='AcctPay' && entitytype=='Vendor'){
      	    alert('You are trying to adjust an A/P account, but the selected currency is not available to one or more vendors on this journal entry.  You must remove these vendors before you change the transaction currency.');
      	}
      	else{
      	    alert('You cannot change the currency because one or more lines exist with entities that are only valid with the selected currency.  You must remove these entities before you change the transaction currency.');
      	}
      	return false;
   	 }
  }
  return true;
}
window.credlimwarn = new function() {
  this.CREDLIM_MANUAL_HOLD = 1;
  this.CREDLIM_BALANCE_EXCEEDS = 2;
  this.CREDLIM_OVERDUE = 4;
  this.private_flags = 0;
  this.hasManualHold = function() { return (this.private_flags & this.CREDLIM_MANUAL_HOLD) != 0; }
  this.hasBalanceExceeds = function() { return (this.private_flags & this.CREDLIM_BALANCE_EXCEEDS) != 0; }
  this.hasOverdue = function() { return (this.private_flags & this.CREDLIM_OVERDUE) != 0; }
  this.hasAnyWarnings = function() { return this.private_flags != 0; }
  this.hasNoWarnings = function() { return this.private_flags == 0; }
  this.setManualHold = function() { this.private_flags |= this.CREDLIM_MANUAL_HOLD; }
  this.setBalanceExceeds = function() { this.private_flags |= this.CREDLIM_BALANCE_EXCEEDS; }
  this.setOverdue = function() { this.private_flags |= this.CREDLIM_OVERDUE; }
  this.resetflags = function() {
  	this.private_flags = 0;
  }
  this.getCreditLimitMessages = function() {
    var msg = '';
    var possibleStatus = [this.CREDLIM_MANUAL_HOLD, this.CREDLIM_BALANCE_EXCEEDS, this.CREDLIM_OVERDUE];
    var daysoverdue = nlapiGetFieldValue('daysoverdue');
    var possibleStatusError = ['Customer is on credit hold.', 'Customer balance exceeds credit limit', 'Customer is ' + daysoverdue + ' days overdue.'];
    for (var i in possibleStatus) if (this.private_flags & possibleStatus[i]) msg += possibleStatusError[i] + '\n';
    return trim(msg);
  }
}
