function validateNotZero(theValue){
  if (theValue !='' && theValue == 0){
    alert('Value cannot be zero.');
    return false;
  }
  return true;
}
function adjustFxRate()
{
formatExchangeRate('toExchangeRate')
formatExchangeRate('fromExchangeRate')
var toCurrVal = parseInt(nlapiGetFieldValue('tocurrency'));
var fromCurrVal = parseInt(nlapiGetFieldValue('fromcurrency'));
var basecurrency = parseInt(nlapiGetFieldValue('basecurrency'));
var currVal;
var fxrateEl;
if(!isNaN(toCurrVal) && !isNaN(fromCurrVal)){
if(toCurrVal != basecurrency && fromCurrVal == basecurrency){ 
fxrateVal=nlapiGetFieldValue('toexchangerate');
currVal=nlapiGetFieldValue('tocurrency');
}
else if(fromCurrVal != basecurrency && toCurrVal == basecurrency) {
fxrateVal=nlapiGetFieldValue('fromexchangerate');
currVal=nlapiGetFieldValue('fromcurrency');
}
else  {
fxrateVal='1'
currVal=nlapiGetFieldValue('fromcurrency');
}
}
else {
fxrateVal=''
currVal=''
}
nlapiSetFieldValue('exchangerate', fxrateVal, false);
nlapiSetFieldValue('currency', currVal, false);
syncAmounts(true);
}
function syncAmounts(acctChange,sourceEl)
{
var rateVal = nlapiGetFieldValue('exchangerate');
var fromAmtVal = nlapiGetFieldValue('fromamount');
var toAmtVal = nlapiGetFieldValue('toamount');
var rateIsOfToAcct = isRateOfToAcct();
if(acctChange && !isNaN(parseFloat(rateVal))){
if(rateIsOfToAcct)
{if (!isNaN(parseFloat(toAmtVal))) nlapiSetFieldValue('fromamount', format_currency(parseFloat(rateVal) * parseFloat(toAmtVal)), false);}
else 
{if (!isNaN(parseFloat(fromAmtVal))) nlapiSetFieldValue('toamount', format_currency(parseFloat(rateVal) * parseFloat(fromAmtVal)), false);}
}
else {
if (isNaN(parseFloat(fromAmtVal)) && !isNaN(parseFloat(toAmtVal)) && !isNaN(parseFloat(rateVal))){
if (rateIsOfToAcct) nlapiSetFieldValue('fromamount', format_currency(parseFloat(toAmtVal) * parseFloat(rateVal)), false);
else nlapiSetFieldValue('fromamount', format_currency(parseFloat(toAmtVal) / parseFloat(rateVal)), false);
}
else if (isNaN(parseFloat(toAmtVal)) && !isNaN(parseFloat(fromAmtVal)) && !isNaN(parseFloat(rateVal))){ 
if (rateIsOfToAcct) nlapiSetFieldValue('toamount', format_currency(parseFloat(fromAmtVal) / parseFloat(rateVal)), false);
else nlapiSetFieldValue('toamount', format_currency(parseFloat(fromAmtVal) * parseFloat(rateVal)), false);
}
else if (!isNaN(parseFloat(fromAmtVal)) && !isNaN(parseFloat(toAmtVal)))
{
if( nlapiGetFieldValue('fromcurrency')  == nlapiGetFieldValue('tocurrency')){
if(sourceEl == 'fromamount')
{
nlapiSetFieldValue('toamount', nlapiGetFieldValue('fromamount'), false)
}
else {
nlapiSetFieldValue('fromamount', nlapiGetFieldValue('toamount'), false)
}
} else 
if (rateIsOfToAcct) {nlapiSetFieldValue('exchangerate', parseFloat(fromAmtVal)/parseFloat(toAmtVal), false); nlapiSetFieldValue('toexchangerate', nlapiGetFieldValue('exchangerate'), false);}
else {nlapiSetFieldValue('exchangerate', parseFloat(toAmtVal)/parseFloat(fromAmtVal), false); nlapiSetFieldValue('fromexchangerate', nlapiGetFieldValue('exchangerate'), false); }
}
}
}
function isRateOfToAcct()
{
  return nlapiGetFieldValue('tocurrency') == nlapiGetFieldValue('currency');
}
function formatExchangeRate(field)
{
  var rate = nlapiGetFieldValue(field);
  if (rate != null && rate.charAt(1) == ',' && rate.charAt(0) == '0')
    nlapiSetFieldValue(field, '0.' + rate.slice(2));
  else if (rate != null && rate.charAt(0) == ',')
    nlapiSetFieldValue(field, '.' + rate.slice(1));
}
