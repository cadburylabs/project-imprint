var value = sel != null ? getSelectValue(sel) : -1;
var value_trandate = getFormElementViaFormName('main_form', 'trandate').value;
var value_ppsetbyuser = getFormElementViaFormName('main_form', 'ppsetbyuser').value;
var value_ppsetbyuservalue = getFormElementViaFormName('main_form', 'ppsetbyuservalue').value;
if (value == -1) {resetlist(sel);
nlOpenWindow('/app/accounting/account/account.nl?type=Bank&prefix=Bank&target=main:fromaccount&label=From+Account', 'newfromaccount', 'width=450, height=450, resizable=yes, scrollbars=yes'); setSelectValue(sel, '');return; }
if (sel.noslaving == true) return;NS.form.setInited(false);
window.status = 'Searching...';
var eventVar = ''; 
if( window.lastKeyStroke == 13 )
{
 window.lastKeyStroke = -1; 
	eventVar = 'enterEvent=T';
}
var serverUrl = '\/app\/accounting\/transactions\/transfer.nl?nexus=1\x26warnnexuschange=F\x26usefirstopenperiod=F\x26&q=fromaccount&si='+encodeURIComponent(value)+'&si_trandate='+encodeURIComponent(emptyIfNull(value_trandate))+'&si_ppsetbyuser='+encodeURIComponent(emptyIfNull(value_ppsetbyuser))+'&si_ppsetbyuservalue='+encodeURIComponent(emptyIfNull(value_ppsetbyuservalue))+(fieldspec == true ? '&f=T' : (fieldspec != null && fieldspec.length > 0 ? '&f='+fieldspec : ''));
if (eventVar.length != 0)serverUrl += '&'+eventVar;if (mach != null)serverUrl += '&mach='+mach;if (addlparams != null)serverUrl += '&'+addlparams;if (window.document.page_is_resetting == true) serverUrl+='&pgreset=T';
serverUrl+='&'+new Date().getTime();
loadSlavingResults(serverUrl, callbacks);}
function Listfromaccount(fld, multi,addlparams) {
var displayField = getFormElementViaFormName('main_form', 'fromaccount');if (displayField != null) {  if (typeof(displayField.isvalid) == 'undefined') { displayField.isvalid = true; }  if (!displayField.isvalid) {     displayField.isvalid = true;    NS.form.setValid(true);    displayField.value = '';  }}var valueField = getFormElementViaFormName('main_form', 'fromaccount');NLPopupSelect_displayLoadingDiv('fromaccount', false);var value_trandate = getFormElementViaFormName('main_form', 'trandate').value;
