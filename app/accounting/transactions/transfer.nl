function sendLineLevelDataFieldSynchronization() {
	var methodRequiresLineLevelData = nlapiGetFieldValue('methodrequireslineleveldata');
	var instrumentRequiresLineLevelData = nlapiGetFieldValue('instrumentrequireslineleveldata');
	var shouldUsePaymentOption = nlapiGetFieldValue('usepaymentoption');
	var profileSupportsLineLevelData = nlapiGetFieldValue('profilesupportslineleveldata');
	if ((shouldUsePaymentOption != 'T' && methodRequiresLineLevelData == 'T') || (shouldUsePaymentOption == 'T' && instrumentRequiresLineLevelData == 'T')) {
		setLineLevelDataField(true, 'T');
	}
	else if (profileSupportsLineLevelData == 'T') {
		setLineLevelDataField(false, 'F');
	}
	else {
		setLineLevelDataField(true, 'F');
	}
}
