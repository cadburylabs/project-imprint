function delete_record(url) {
	var prompt = (url == 'void.jsp' 
    ? (nlapiGetFieldValue('cleared') == 'T' 
      ? 'This transaction is cleared. If you void it without a voiding journal entry, your account reconciliation may have inconsistencies as a result, like an incorrect balance.'
      : 'Are you sure you want to void this transaction?')
    : 'Are you sure you want to delete this transaction?');
if (document.forms['main_form'].linked.value == 'T') {
  if (url == 'void.jsp') {
  var deleteOrVoid = 'You cannot void this transaction because there are other transactions linked to this one.Click <a href=\"/app/accounting/transactions/payments.nl?id=null&label=Transfer&type=transfer&alllinks=T\">here</a> to see a list of these transactions.';
  } else {
  var deleteOrVoid = 'You cannot delete this transaction because there are other transactions linked to this one.Click <a href=\"/app/accounting/transactions/payments.nl?id=null&label=Transfer&type=transfer&alllinks=T\">here</a> to see a list of these transactions.';
  } ;
  showAlertBox('errornotificationsdiv', 'ERROR', deleteOrVoid, NLAlertDialog.TYPE_HIGH_PRIORITY);
  return false;
}
if (url != 'void.jsp' || confirm(prompt)) {
if (url == 'void.jsp'){
document.forms['main_form'].action = addParamToURL(document.forms['main_form'].action,'void','Void');
document.forms['main_form'].onsubmit=null;document.forms['main_form'].bonsubmitisnull=true
NS.form.setChanged(false);
return true;
}else{
nlExtOpenWindow('\/app\/accounting\/transactions\/deletionreason\/trandeletionreason.nl?nKey=null', 'deletionreasonpopup', 420, 300, this, false, 'null'.replace('<tranid>', nlapiGetFieldValue('tranid')));
return false;
}
}
else return false;
}
function appendMastersForQueryRequest(sublistId, queryFieldId, url){
var masters = null;
if(sublistId == null){ masters = fmasters.main[queryFieldId]; }
else if(sublistId != null){ masters = fmasters.sublists[sublistId] ? fmasters.sublists[sublistId][queryFieldId] : null; }
if(masters && Array.isArray(masters)){
masters.forEach(function(master){
var dotIndex = master.indexOf('.'), sublistId, fieldId;
if(dotIndex != -1){ sublistId = master.substring(0, dotIndex); fieldId = master.substring(dotIndex+1); }else{ fieldId = master };
var val = sublistId ? nlapiGetCurrentLineItemValue(sublistId, fieldId) : nlapiGetFieldValue(fieldId);
url = addParamToURL(url, 'si_'+fieldId, val && encodeURIComponent(val));
})
}
return url;
}
function NLEntryForm_querySelectText(fldname, machine, linenum, value) {
if ( isValEmpty( value ) ) return null;
var url = '\/app\/accounting\/transactions\/transfer.nl?nexus=1\x26warnnexuschange=F\x26usefirstopenperiod=F';
var id = getFormElementViaFormName('main_form', 'id').value;
if ( !isValEmpty( id ) && id != -1 ) url = addParamToURL( url, 'id', id ); 
url = addParamToURL( url, 'q', fldname ); 
url = addParamToURL( url, 'si', encodeURIComponent(value) ); 
url = appendMastersForQueryRequest(machine, fldname, url);
url = addParamToURL( url, 'lookuplabel', 'T' ); 
if ( !isValEmpty( machine ) ) url = addParamToURL( url, 'machine', machine ); 
var response = new NLXMLHttpRequest().requestURL( url ).getBody();
eval( response.replace(/^\s*<!--[\s\S]*?-->\s*$/gm, '') );
return selectmap;
}
function NLEntryForm_querySelectValue(fldname, machine, text) {
if ( isValEmpty( text ) ) return null;
var url = '\/app\/accounting\/transactions\/transfer.nl?nexus=1\x26warnnexuschange=F\x26usefirstopenperiod=F';
var id = getFormElementViaFormName('main_form', 'id').value;
if ( !isValEmpty( id ) && id != -1 ) url = addParamToURL( url, 'id', id ); 
url = addParamToURL( url, 'q', fldname ); 
url = addParamToURL( url, 'st', encodeURIComponent( text ) ); 
url = appendMastersForQueryRequest(machine, fldname, url);
url = addParamToURL( url, 'resolvelabel', 'T' ); 
if ( !isValEmpty( machine ) ) url = addParamToURL( url, 'machine', machine ); 
var response = new NLXMLHttpRequest().requestURL( url ).getBody();
eval( response.replace(/^\s*<!--[\s\S]*?-->\s*$/gm, '') );
return selectmap;
}
