function NLTranEntryForm_validateExchangeRate()
{
if (nlapiGetFieldValue('exchangerate') != null  && nlapiGetFieldValue('exchangerate') != ''  && nlapiGetFieldValue('exchangerate') <= 0.0) {
  alert('The exchange rate must be greater than 0.');
