function save_record(lastcall, allowEnhancedResult) {
var _saverec = function _saverec(lastcall) {
if(document.forms['main_form'].bonsubmitisnull) return true;
if (!NS.form.isInited()) return false;
for(key in window.subrecordcache)
{
    if (window.subrecordcache.hasOwnProperty(key) && window.subrecordcache[key])
    {
        window.subrecordcache[key].commit();
    }
}
var form = document.forms['main_form'];
if (form.submitted) {
if (form.submitted.value == 'T') { 
var resubmit = false;
if (form.clickedback.value == 'T')
resubmit = confirm('You have already submitted this form, would you like to submit it again?'); 
else alert('You have already submitted this form.');
if(!resubmit) return false;
}
}
try {
TransferFieldValues();
if (nlapiGetFieldValue('fromaccount') == nlapiGetFieldValue('toaccount'))
{ alert('Please choose two different bank accounts.'); return false; }
if(!isNaN(parseInt(nlapiGetFieldValue('fromcurrency'))) && !isNaN(parseInt(nlapiGetFieldValue('tocurrency'))) && nlapiGetFieldValue('fromcurrency') != nlapiGetFieldValue('basecurrency') && nlapiGetFieldValue('tocurrency') != nlapiGetFieldValue('basecurrency') && nlapiGetFieldValue('fromcurrency') != nlapiGetFieldValue('tocurrency'))
{ alert('When currencies of accounts differ, at least one of the accounts must be a base currency account.'); return false; }
var _lastResult = nlapiSaveRecord();
var isSaveRecordValid = validationResultToBoolean(_lastResult);
if (!isSaveRecordValid) return _lastResult;
var _a_fld = new Array(getFormElementViaFormName('main_form', 'fromaccount'),getFormElementViaFormName('main_form', 'toaccount'),getFormElementViaFormName('main_form', 'trandate'),getFormElementViaFormName('main_form', 'fromamount'),getFormElementViaFormName('main_form', 'toamount'));
var _a_lbl = new Array('From Account','To Account','Date','Amount','Amount');
var emptylabels = checkMandatoryFields(_a_fld,_a_lbl,null,null,true);
if (emptylabels.length>0) {
return { valid: false, fields: emptylabels.map(function(v){return {id: _a_fld[_a_lbl.indexOf(v)]};}), messages: ['Please enter value(s) for: ' + emptylabels.join(', ')] }
}
enableDisabledFields(isSaveRecordValid); 
var kPeriod = nlapiGetFieldValue('postingperiod');
if (kPeriod) {
	var iPeriod = + kPeriod + 1000;
	if (pp_ss[iPeriod] && (nlapiStringToDate(nlapiGetFieldValue('trandate')) < nlapiStringToDate(pp_ss[iPeriod]) || nlapiStringToDate(nlapiGetFieldValue('trandate')) > nlapiStringToDate(pp_es[iPeriod]))) {
		if (!confirm('The transaction date you specified is not within the current accounting period. Backdating a transaction to a previous period requires all periods from the revised date to be open and remain open during the costing run, or errors will result. In addition, backdating a transaction to a previous period will likely cause costing to run again for multiple transactions. This may result in extended costing runs and modified financial postings for the previous periods. Click OK to backdate to a previous period. If you do, ensure that all accounting periods between the transaction date and today are open and will remain open during the costing update before proceeding. Click Cancel to change the transaction date.')) return false;
	}
}
if (nlapiGetField('tranid') != null)
{
    nlapiSetFieldDisabled('tranid', false);
}
if (!NLTranEntryForm_validateExchangeRate()) return false;
{
    var cardNumber = nlapiGetFieldValue('ccnumber') || '';
    if (cardNumber.length > 0) {
        var cardPanId = nlapiGetFieldValue('ccpanid') || '';
        if (cardPanId.length > 0) {
            if (cardNumber.indexOf('*') < 0 && !checkccnumber('ccnumber')) { return false; }
        } else {
           if (!checkccnumber('ccnumber')) { return false; }
        }
    }
}

document.forms['main_form'].elements['exchangerate'].value=getFormElementViaFormName('main_form', 'exchangerate').value
if (document.forms['main_form'].elements['subsidiary'].disabled && document.forms['main_form'].elements['subsidiary_send'] != null) document.forms['main_form'].elements['subsidiary_send'].value=document.forms['main_form'].elements['subsidiary'].value
{
    var cardNumber = nlapiGetFieldValue('ccnumber') || '';
    if (cardNumber.length > 0) {
        var cardPanId = nlapiGetFieldValue('ccpanid') || '';
        if (cardPanId.length > 0) {
            if (cardNumber.indexOf('*') < 0 && !checkccnumber('ccnumber')) { return false; }
        } else {
           if (!checkccnumber('ccnumber')) { return false; }
        }
    }
}

for(key in window.subrecordcache)
{
    if (window.subrecordcache.hasOwnProperty(key) && window.subrecordcache[key])
    {
        window.subrecordcache[key].commit();
    }
}
} catch(err) {
  alert('You cannot submit this form due to an unexpected error.'); return false;
}
TransferFieldValues();
setWindowChanged(window, false);
if(lastcall == true && form.submitted) form.submitted.value='T';
transferFileInputInTabs();
return true;
}
var result = _saverec(lastcall);
if (result){
}
if (!allowEnhancedResult) result = handleValidationResult(result);
return result;
}
