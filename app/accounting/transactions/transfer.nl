function create_memorized_transaction(create) {
    var actionsave = document.forms['main_form'].action;
    document.forms['main_form'].action = addParamToURL(document.forms['main_form'].action,'memorize','T');
    if (!create)
    {
        document.forms['main_form'].action = addParamToURL(document.forms['main_form'].action,'memupdate','T');
    }
    if (NS.form.isValid() && save_record())  {
    NS.form.setChanged(true);
    return true; }
    document.forms['main_form'].action = actionsave;
    return false;
}
function do_memorize() {
  NS.form.setChanged(true);
  var prompt = 'You have already memorized this transaction.\n\nClick OK to create another memorized transaction.\n\nClick Cancel to update this memorized transaction.';
  if (document.forms['main_form'].elements['memdoc'] && !confirm(prompt))
      return create_memorized_transaction(false);
  else
      return create_memorized_transaction(true);
}
function doVoid(bReversal)
{
  if (!bReversal)
    return delete_record('void.jsp');
  else
    document.location='/app/accounting/transactions/journal.nl?e=T&void=T&memdoc=0&transform=transfer&id='+getFormElementViaFormName('main_form', 'id').value;
}
function new_message(urlparams,type){
var extraparams = (type == 'ATTACH' ? 'incoming=T' : 'templatetype='+type);
var urlparamsstring = '';
var i = 0;
for (i = 0; i < urlparams.length; ++i)
{
if (!isValEmpty(urlparams[i][1]))
{
urlparamsstring += urlparams[i][0] + '=' + urlparams[i][1] + '&';
}
}
nlOpenWindow('/app/crm/common/crmmessage.nl?' + urlparamsstring + 'l=T&' + extraparams, 'messagepopup', 'resizable=yes,scrollbars=yes,width=700,height=500')
}
function addShortcut() {
nlOpenWindow('/core/pages/addShortcut.nl?label='+encodeURIComponent('Transfer')+'&taskid=EDIT_TRAN_TRANSFER&params=nexus%3D1%26warnnexuschange%3DF%26usefirstopenperiod%3DF','addshortcut','scrollbars=no,width=450,height=250');
}
function localEval(s) {
return eval(s);
}
function NLDisplayTab(tname,shown) {
  var tab  = document.getElementById(tname+'lnk');
  tab.className = shown ? 'formtabon' : 'formtaboff';
  var firstTab = tab.previousSibling.getAttribute('side')=='0';
  var lastTab = tab.nextSibling.getAttribute('side')=='1';
  if (firstTab){ 
    tab.previousSibling.className = shown ? 'formtabseplon' : 'formtabseploff';
    tab.previousSibling.firstChild.className = shown ? 'formtabsepclon' : 'formtabsepcloff';
  } 
  if (lastTab){ 
    tab.nextSibling.className = shown ? 'formtabsepron' : 'formtabseproff';
    tab.nextSibling.firstChild.className = shown ? 'formtabsepcron' : 'formtabsepcroff';
  } 
  document.getElementById(tname+'txt').className = shown ? 'formtabtext formtabtexton':'formtabtext formtabtextoff';
} 


function isTabShown(tname) {
    var tab = NS.jQuery('#'+tname+'_div');
    return !tab.length || (tab.css('display') != 'none');
}

function ShowHideTab(tname,shown) {
    var tabDiv = NS.jQuery('#'+tname+'_div');
    if (!tabDiv.length || tabDiv.css('display') == (shown ? '' : 'none')) return;

    NS.jQuery('#'+tname+'_wrapper').css('display', (shown ? '' : 'none'));

    var machs = allmachs[tname].split(',');
    var mach = vismachs[tname];
    var dotmachs = '';
    if (shown) {
        var i;
        for (i=0;i<machs.length;i++) {
            var dotmach = machs[i];
            if (dotmach != null && dotmach != mach && NS.jQuery('#'+dotmach+'_layer').length && document.forms.main_form.elements[dotmach+'dotted'] != null && document.forms.main_form.elements[dotmach+'dotted'].value=='F')
                dotmachs += (dotmachs.length > 0 ? String.fromCharCode(5) : '') + dotmach;
        }
    }

    tabDiv.css('visibility', '');
    tabDiv.css('display', shown ? '' : 'none');
    NLDisplayTab(tname, shown);
    if (shown && mach != null && NS.jQuery('#'+mach+'_layer').is(":visible") && document.forms.main_form.elements[mach+'loaded'] != null && document.forms.main_form.elements[mach+'loaded'].value=='F')
        refreshmachine(mach, null, true, dotmachs.length > 0 ? dotmachs : null);
    else if (shown && dotmachs.length > 0)
        refreshmachine(null, null, true, dotmachs);
        if(shown) {
            getFormElementViaFormName('main_form', 'selectedtab').value = tname;
        }
    if (shown && (typeof NetSuite != 'undefined') && (typeof NetSuite.RTEManager != 'undefined'))
        NetSuite.RTEManager.resyncSizeAll();
}

function collapsetab(lname,sethidden) {
    expandCollapseTab(lname, sethidden);
}

var sCurrentlySelectedTab = 'custom';
function ShowTab(lname, bIgnoreInited) {

NS.jQuery('.uir_form_tab_container:eq(0)').trigger({
	type: "nsSelect",
	message: "nsSelect fired.",
	time: new Date()
	}, {}
);

if ((bIgnoreInited || NS.form.isInited()) && NS.form.isValid()) {
        if(lname == sCurrentlySelectedTab) return;
        ShowHideTab(lname, true);
        ShowHideTab(sCurrentlySelectedTab, false);
        sCurrentlySelectedTab = lname;
		if (window.NLMachine_clearFocus) {
			NLMachine_clearFocus();
		}
                    if (lname == 'custom') {
                        setSelectFocus(getFormElementViaFormName('custom_form', 'custbody_15529_vendor_entity_bank'))

                    }
    }
}

function CollapseAll(hidden) {
    if (NS.form.isInited() && NS.form.isValid()) {
            
            collapsetab('custom', hidden);
    }
}function TransferFieldValues() {

 window.tabFormsToSubmit = [];
 var destform = document.forms['main_form'];
 var elem;
 var destElem;
 var origElem;
 if ( destform == null ) return;
 var tabForm = null;
 if (document.layers !== undefined)
   tabForm = document.layers['custom'].document.forms['custom_form'];
 else
   tabForm = document.forms['custom_form'];
 var fcustom = tabForm;
 if (tabForm) window.tabFormsToSubmit.push(tabForm)
destElem = getFormElement(destform,'custbody_15529_vendor_entity_bank');
origElem = getFormElement(fcustom,'custbody_15529_vendor_entity_bank');
if (destElem && origElem) {
elem = origElem;
destElem.value = getSelectValue(elem);
 }
destElem = getFormElement(destform,'custbody_15529_emp_entity_bank');
origElem = getFormElement(fcustom,'custbody_15529_emp_entity_bank');
if (destElem && origElem) {
elem = origElem;
destElem.value = getSelectValue(elem);
 }
}

function transferFileInputInTabs() {
    var tabForms = window.tabFormsToSubmit;
    if (!tabForms) return;
    var destform = document.forms['main_form'];
    if (destform == null) return;
    for (var i=0; i<tabForms.length; i++)
    {
        var tabform = tabForms[i];
        for (var j=0; j<tabform.elements.length; j++)
        {
            var inpElem = tabform.elements[j];
            if (inpElem.type == 'file' && inpElem.value)
            {
                var clonedElem = inpElem.cloneNode(true); 
                inpElem.parentElement.insertBefore(clonedElem, inpElem);
                inpElem.style.display='none';
                destform.removeChild(destform.elements[inpElem.name]);
                destform.appendChild(inpElem.parentElement.removeChild(inpElem));
            }
        }
    }
}

