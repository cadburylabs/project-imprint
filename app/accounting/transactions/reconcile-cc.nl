<div style="position:fixed;top:0;left:0;right:0;z-index:2147483647;background:#2563eb;color:#fff;font-family:system-ui,-apple-system,sans-serif;font-size:14px;padding:8px 16px;text-align:center;">This is a frontend static clone of NetSuite, built to help people learn about it before buying it. Learn more <a href="https://trycadbury.com/blog/project-imprint" style="color:#fff;text-decoration:underline;">here</a>.</div><script>(function(){
  var busy = false;
  var fix = function() {
    if (busy) return;
    busy = true;
    document.querySelectorAll('div[data-widget="Popover"]').forEach(function(p) {
      var r = p.style.right;
      if ((r === '0px' || r === '0' || r === '') && p.style.minWidth !== '360px') {
        p.style.setProperty('min-width', '360px', 'important');
      }
    });
    document.querySelectorAll('a[href*="changeaccount.nl"]').forEach(function(a) {
      var item = a.closest('div[data-widget="MenuItem"]');
      if (item && item.style.display !== 'none') item.style.setProperty('display', 'none', 'important');
      var group = item && item.parentElement && item.parentElement.querySelector('div[data-widget="MenuGroup"]');
      if (group && group.style.display !== 'none') group.style.setProperty('display', 'none', 'important');
    });
    busy = false;
  };
  var obs = new MutationObserver(fix);
  document.addEventListener('DOMContentLoaded', function() {
    obs.observe(document.body, { childList: true, subtree: true, attributes: true, attributeFilter: ['style'] });
    fix();
  });
})();</script><style>#pageContainer{margin-top:31px!important;}[data-header-section="logos"]{visibility:hidden!important;}div[data-widget="MenuItem"]:has(a[href*="changeaccount.nl"]){display:none!important;}div[data-widget="MenuGroup"]:has(~ div[data-widget="MenuItem"] a[href*="changeaccount.nl"]){display:none!important;}div[data-widget="Popover"][style*="right: 0"]{min-width:420px!important;}</style><style>#pageContainer{margin-top:31px!important;}div[data-widget="MenuItem"]:has(a[href*="changeaccount.nl"]){display:none!important;}div[data-widget="MenuGroup"]:has(~ div[data-widget="MenuItem"] a[href*="changeaccount.nl"]){display:none!important;}div[data-widget="Popover"][style*="right: 0"]{min-width:420px!important;}</style>
<body onload="page_init()" class="error-page uir-error-page">
	<div class="uir-page-header-redwood uir-page-header-redwood--production"><img class="uir-logo" src="images/logos/netsuite-oracle.svg"></div>
<div class="uir-error-page-content">
	<div class="uir-error-page-title">Notice</div>
	<div class="uir-error-page-message">You must have a credit card account to perform this operation.  Click <a href="/app/accounting/account/accounts.nl" rel="nofollow">here</a> to add one.</div>
	<div class="uir-error-page-button">        
	<div id="tbl_goback"><div id="tr_goback"> 
    <button type="button" class="uir-button" data-button-type="primary" data-with-icon="false" data-with-label="true" id="goback" name="goback" data-nsps-type="button" data-nsps-label="Go Back" onclick="history.back(); return false;" value="Go Back">
			<span class="uir-button-label">Go Back</span>
    </button>
	</div></div>
    
</div>
</div>

