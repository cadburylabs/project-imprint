.ir-beacon::before { animation: 1s linear 0s infinite normal none running active; background-color: initial; box-shadow: rgb(18, 188, 141) 0px 0px 2px 2px; content: ""; }
@-webkit-keyframes active { 
  0% { opacity: 1; transform: scale(1); }
  70% { opacity: 0; transform: scale(2.5); }
  100% { opacity: 0; }
}
@keyframes active { 
  0% { opacity: 1; transform: scale(1); }
  70% { opacity: 0; transform: scale(2.5); }
  100% { opacity: 0; }
}
