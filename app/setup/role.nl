.uir-menu { position: absolute; border: 1px solid var(--nsn-uif-redwood-color-light-border-divider); box-shadow: rgba(0, 0, 0, 0.2) 0px 2px 8px 1px; overflow: hidden; border-radius: var(--nsn-uif-redwood-border-rounded-corners); background-color: var(--nsn-uif-redwood-color-light-neutral-0); }
