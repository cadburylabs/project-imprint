body[data-page-category="hosted_center"] .iBullet { display: inline-flex; width: 6px; height: 15px; margin: 2px; background-image: url("images/chiles/dashboard_icons.png"); background-position: 0px -276px; background-repeat: no-repeat; text-decoration: none; }
body[data-page-category="hosted_center"] .portletBgColor > td > table { margin-left: var(--nsn-uif-redwood-spacing-2-x); margin-top: var(--nsn-uif-redwood-spacing-2-x); background-color: var(--nsn-uif-redwood-color-light-neutral-20); border-radius: 8px; padding: 8px; }
.uir-shm-legal-note { padding: 0 var(--nsn-uif-redwood-spacing-6-x); }
.uir-subsidiary-help-msg { font-size: var(--nsn-uif-redwood-font-size-body-xs); font-weight: var(--nsn-uif-redwood-font-weight-semi-bold); color: var(--nsn-uif-redwood-color-light-text-secondary); }
.uir-integration-download-component { display: flex; flex-direction: column; gap: var(--nsn-uif-redwood-spacing-4-x); padding: var(--nsn-uif-redwood-spacing-6-x) var(--nsn-uif-redwood-spacing-6-x); }
.uir-integration-download-component h3 { margin: 0px; }
.uir-integration-download-component-text a { text-decoration: underline rgba(255, 255, 255, 0); transition: text-decoration-color var(--nsn-uif-redwood-animation-duration-medium); color: var(--nsn-uif-redwood-color-light-text-link); fill: var(--nsn-uif-redwood-color-light-text-link); }
.uir-integration-download-component-text a:hover { text-decoration-color: var(--nsn-uif-redwood-color-light-text-link); }
.uir-timesheets-list-legend > td { padding: var(--nsn-uif-redwood-spacing-1-x) !important; }
.uir-siteadmin h1.bigboldtext { margin: 0px; font-weight: var(--nsn-uif-redwood-font-weight-bold); font-size: var(--nsn-uif-redwood-font-size-body-xl); }
.uir-siteadmin p.bigboldtext { margin: 0px; font-weight: var(--nsn-uif-redwood-font-weight-bold); font-size: var(--nsn-uif-redwood-font-size-body-lg); }
.uir-terms-of-service { padding: 0 var(--nsn-uif-redwood-spacing-4-x); }
.uir-terms-of-service-buttons { padding: 0 var(--nsn-uif-redwood-spacing-6-x); }
.uir-bundle-tos-disclaimer { padding: 0 var(--nsn-uif-redwood-spacing-2-x); }
.uir-bundle-tos-body { padding: 0 var(--nsn-uif-redwood-spacing-2-x); }
