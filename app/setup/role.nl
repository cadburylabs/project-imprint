.ns-menu .ns-menuitem a { display: flex; align-items: center; justify-content: center; font-size: var(--nsn-uif-redwood-font-size-body-sm); font-weight: var(--nsn-uif-redwood-font-weight-semi-bold); padding: 0 var(--nsn-uif-redwood-spacing-4-x); height: 36px; text-decoration: none; background-color: transparent; border-radius: var(--nsn-uif-redwood-border-rounded-corners-mid); }
