.uir-session-blocker { position: fixed; width: 100%; height: 100%; top: 0px; left: 0px; z-index: 20000; background-color: rgba(54, 103, 125, 0.95); }
.uir-alert-box { display: flex; align-items: start; padding: var(--nsn-uif-redwood-spacing-3-x); gap: var(--nsn-uif-redwood-spacing-2-x); border-bottom: 1px solid var(--nsn-uif-redwood-color-light-border-divider); }
.uir-alert-box .uir-alert-box-icon-image { width: 22px; height: 22px; }
