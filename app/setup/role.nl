.uir-kpi-machine-snapshot > a { display: inline-flex; }
.add-optional-kpi-button, .remove-optional-kpi-button { color: var(--nsn-uif-redwood-color-light-text-link); background: transparent; border-width: medium; border-style: none; border-color: currentcolor; border-image: initial; border-radius: var(--nsn-uif-redwood-border-rounded-corners-mid); padding: 4px; cursor: pointer; }
.add-optional-kpi-button:hover, .remove-optional-kpi-button:hover { background-color: var(--nsn-uif-redwood-color-light-overlay-hover); }
.optional-remove-kpi-button-layout-class { margin-left: 8px; }
#recurrence_form .table_fields td { display: flex; align-items: center; }
#recurrence_form .sp_CompoundField { display: inline-flex; align-items: center; gap: var(--nsn-uif-redwood-spacing-1-x); font-size: var(--nsn-uif-redwood-font-size-body-2-xs); margin-left: var(--nsn-uif-redwood-spacing-3-x); }
#recurrence_form .uir-table-fields-wrapper { width: auto !important; }
#recurrence_form div[data-walkthrough*="spacer"] { display: none; }
#recurrence_form .uir-onoff { margin: var(--nsn-uif-redwood-spacing-1-x) 0 !important; }
#recurrence_form .uir-onoff .uir-label { margin-bottom: 0px !important; }
.uir-availability-nav { display: flex; align-items: center; gap: var(--nsn-uif-redwood-md-spacing-3-x); }
.uir-availability-backward, .uir-availability-forward { display: flex; }
.uir-availability-backward > img, .uir-availability-forward > img { width: 20px; height: 20px; }
table.uir-availability-legend-table { border: 1px solid rgb(230, 230, 230); background: rgb(250, 250, 250); padding: 5px 10px; }
table.uir-availability-legend-table tbody tr td { height: 20px; }
table.uir-availability-legend-table .uir-availability-tentative { background: url("images/pattern_hash_gray_lg.png") white; border: 1px solid rgb(233, 233, 233); width: 20px; }
table.uir-availability-legend-table .uir-availability-tentative + td { padding-right: 15px; }
table.uir-availability-legend-table .uir-availability-unavailable { background: var(--nsn-uif-redwood-color-light-brand-60); border: 1px solid rgb(233, 233, 233); width: 20px; }
table.uir-availability-legend-table td img { display: none; }
.uir-availability-header > td { background-color: var(--nsn-uif-redwood-color-light-neutral-20); text-align: center; text-transform: uppercase; padding: 5px 0px; vertical-align: middle; border-bottom-width: medium; border-bottom-style: none; border-bottom-color: currentcolor; }
.uir-availability-header .smalltext { color: rgb(85, 85, 85); font-size: 11px; }
.uir-availability-row { height: 40px; }
.uir-availability-row > td:first-child { text-align: left; font-weight: normal; padding-left: 10px !important; }
.uir-availability-row > td { border-top: 1px solid rgb(230, 230, 230); border-bottom-width: medium; border-bottom-style: none; border-bottom-color: currentcolor; }
.uir-availability-row .uir-availability-available, .uir-availability-row .uir-availability-name { background: white; }
.uir-availability-row .uir-availability-tentative { background: url("images/pattern_hash_gray_lg.png") white; }
.uir-availability-row .uir-availability-unavailable { background: var(--nsn-uif-redwood-color-light-brand-60); }
.uir-availability-cell { border-left: 1px solid rgb(233, 233, 233); }
.uir-availability-separator { background: rgb(230, 230, 230); }
.uir-install-spinner { display: inline-flex; width: 24px; height: 24px; background-size: contain; background-image: url("uiredwood/img/icon/refresh.svg"); animation: 4s linear 0s infinite normal none running uir-spin-animation; }
#div__prelabel { padding: var(--nsn-uif-redwood-spacing-1-x) var(--nsn-uif-redwood-spacing-6-x); }
.uir-mass-update-fields { margin-top: var(--nsn-uif-redwood-spacing-4-x); width: calc(100% - 48px); border: 1px solid var(--nsn-uif-redwood-color-light-border-divider); border-radius: var(--nsn-uif-redwood-border-rounded-corners-mid); table-layout: fixed; }
.uir-mass-update-fields > tbody > tr > td { height: 36px; padding: 6px var(--nsn-uif-redwood-spacing-4-x); border-bottom: 1px solid var(--nsn-uif-redwood-color-light-border-divider); vertical-align: middle; }
.uir-mass-update-fields-label a { font-size: var(--nsn-uif-redwood-font-size-body-xs); font-weight: var(--nsn-uif-redwood-font-weight-semi-bold); color: var(--nsn-uif-redwood-color-light-text-secondary); }
.uir-mass-update-fields-label a.smallgraytextnolink { text-decoration: none; }
.uir-mass-update-fields-header { font-weight: var(--nsn-uif-redwood-font-weight-semi-bold); }
.uir-mass-update-fields-header > td:nth-child(1), .uir-mass-update-fields-header > td:nth-child(2) { width: 10%; }
.uir-mass-update-fields-preview > tbody > tr:first-child > td { font-weight: var(--nsn-uif-redwood-font-weight-bold); }
.uir-mass-update-fields-preview td { padding-left: var(--nsn-uif-redwood-spacing-3-x); }
.uir-bas-footer { margin: 0 var(--nsn-uif-redwood-spacing-6-x) var(--nsn-uif-redwood-spacing-6-x) var(--nsn-uif-redwood-spacing-6-x); }
