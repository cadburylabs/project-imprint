html { font-family: "Oracle Sans", "Helvetica Neue", sans-serif; font-size: var(--nsn-uif-redwood-font-size-body-sm); font-weight: var(--nsn-uif-redwood-font-weight-regular); font-variant-numeric: tabular-nums; color: var(--nsn-uif-redwood-color-light-text-primary); fill: var(--nsn-uif-redwood-color-light-text-primary); -webkit-font-smoothing: antialiased; padding: 0px !important; margin: 0px !important; }
body { margin: 0px !important; padding: 0px !important; }
#pageContainer { display: flex !important; flex-direction: column; }
div#body { position: relative; display: flex; flex-direction: column; width: 100%; }
div#outerwrapper { display: flex; flex-direction: column; position: relative; width: 100%; }
html[data-scroll-behavior="natural"], html[data-scroll-behavior="app"] { height: 100%; overflow: hidden !important; }
html[data-scroll-behavior="natural"] > body, html[data-scroll-behavior="app"] > body { height: 100%; overflow: hidden !important; }
html[data-scroll-behavior="natural"] #pageContainer, html[data-scroll-behavior="app"] #pageContainer { height: 100%; }
html[data-scroll-behavior="natural"] #body, html[data-scroll-behavior="app"] #body { flex-grow: 1; min-height: 0px !important; }
html[data-scroll-behavior="natural"] #outerwrapper, html[data-scroll-behavior="app"] #outerwrapper { min-height: 0px !important; height: 100%; }
