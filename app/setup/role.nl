.popupsuggest .autosuggcell, .popupsuggest .dropdownSelected { font-size: var(--nsn-uif-redwood-font-size-body-sm); min-height: var(--nsn-uif-redwood-md-spacing-12-x); padding: var(--nsn-uif-redwood-md-spacing-3-x) var(--nsn-uif-redwood-md-spacing-4-x); cursor: pointer; }
.popupsuggest .autosuggcell:not(.dropdownSelected):hover { background-color: var(--nsn-uif-redwood-color-light-overlay-hover); }
.popupsuggest .autosuggcell { border-top: 1px solid transparent !important; border-bottom: 1px solid transparent !important; }
.popupsuggest .dropdownSelected { background-color: var(--nsn-uif-redwood-color-light-surface-selected); border-top: 1px solid var(--nsn-uif-redwood-color-light-border-selected) !important; border-bottom: 1px solid var(--nsn-uif-redwood-color-light-border-selected) !important; }
.popupouter { display: block; border-radius: var(--nsn-uif-redwood-border-rounded-corners-mid); overflow: hidden; width: auto !important; position: static !important; }
.popupouter div { border-width: medium !important; border-style: none !important; border-color: currentcolor !important; border-image: initial !important; }
.popupouter .uir-filter-area { display: flex; flex-direction: column; gap: var(--nsn-uif-redwood-spacing-1-x); padding: var(--nsn-uif-redwood-spacing-2-x) var(--nsn-uif-redwood-spacing-4-x); background-color: var(--nsn-uif-redwood-color-light-surface-neutral-low); border-bottom: 1px solid var(--nsn-uif-redwood-color-light-border-divider) !important; }
.popupouter .uir-filter-area select { margin: var(--nsn-uif-redwood-size-4-xs); }
.popupouter .uir-filter-area #psls { width: 100%; max-width: 100%; }
.popupouter .uir-filter-area input { margin: var(--nsn-uif-redwood-size-4-xs); }
.popupouter .uir-filter-area #st { width: 280px; }
.popupouter .uir-filter-area .uir-button-wrapper { margin: var(--nsn-uif-redwood-size-4-xs) var(--nsn-uif-redwood-spacing-2-x); }
.popupouter .uir-filter-area + img { display: none; }
.popupouter table { border-width: medium !important; border-style: none !important; border-color: currentcolor !important; border-image: initial !important; }
.popupouter .uir-popup-select-header { display: flex; align-items: center; height: 36px; padding: 0 var(--nsn-uif-redwood-spacing-2-x) 0 var(--nsn-uif-redwood-spacing-4-x); background-color: var(--nsn-uif-redwood-color-light-brand-130); }
.popupouter .uir-popup-select-header-title { flex-grow: 1; font-size: var(--nsn-uif-redwood-font-size-body-md); font-weight: var(--nsn-uif-redwood-font-weight-bold); color: var(--nsn-uif-redwood-color-light-text-inverse); }
.popupouter .uir-popup-select-close-button { margin-left: var(--nsn-uif-redwood-spacing-2-x); }
.popupouter .uir-popup-select-close-button a { display: flex; align-items: center; justify-content: center; width: var(--nsn-uif-redwood-md-spacing-9-x); height: var(--nsn-uif-redwood-md-spacing-9-x); border-radius: var(--nsn-uif-redwood-border-rounded-corners-mid); }
.popupouter .uir-popup-select-close-button a:hover { background-color: rgba(255, 255, 255, 0.04); }
.popupouter .uir-popup-select-close-button svg { width: var(--nsn-uif-redwood-md-spacing-5-x); height: var(--nsn-uif-redwood-md-spacing-5-x); fill: var(--nsn-uif-redwood-color-light-text-inverse); }
.popupouter img[src="/images/nav/stretch.gif"] { display: none; }
.popupouter .uir-popup-select-multiple-header { padding: var(--nsn-uif-redwood-spacing-2-x) var(--nsn-uif-redwood-spacing-4-x); display: flex; }
.popupouter .uir-popup-select-multiple-header > div { flex-grow: 1; font-size: var(--nsn-uif-redwood-font-size-body-md); font-weight: var(--nsn-uif-redwood-font-weight-bold); }
.popupouter .uir-popup-select-buttons { padding: var(--nsn-uif-redwood-spacing-2-x) var(--nsn-uif-redwood-spacing-4-x) var(--nsn-uif-redwood-spacing-4-x) var(--nsn-uif-redwood-spacing-4-x); }
.popupouter .uir-popup-select-buttons .uir-button-wrapper { margin-right: var(--nsn-uif-redwood-spacing-4-x); }
.popupouter .uir-popup-select-buttons tr[height="7"] { display: none; }
.popupouter #inner_popup_div { height: 250px; overflow: hidden auto !important; }
.popupouter #inner_popup_div tr td:first-child:not([colspan="2"]) { display: none; }
.popupouter #inner_popup_div tr td { font-size: var(--nsn-uif-redwood-font-size-body-sm); padding: 0 var(--nsn-uif-redwood-spacing-2-x); cursor: pointer; vertical-align: middle !important; }
.popupouter #inner_popup_div tr td a { display: flex; align-items: center; cursor: pointer; text-decoration: none; }
.popupouter #inner_popup_div tr:hover td { background-color: var(--nsn-uif-redwood-color-light-overlay-hover); }
.popupouter #inner_popup_div[data-multiple="false"] tr { height: var(--nsn-uif-redwood-md-spacing-11-x); }
.popupouter #inner_popup_div[data-multiple="false"] td:nth-child(2) { padding-left: var(--nsn-uif-redwood-spacing-6-x); }
.popupouter #inner_popup_div[data-multiple="true"] tr { height: var(--nsn-uif-redwood-md-spacing-8-x); }
@keyframes skeleton { 
  0% { color: var(--nsn-uif-redwood-color-light-text-primary); }
  100% { color: var(--nsn-uif-redwood-color-light-text-secondary); }
}
#popup_load_message { height: 120px; }
body > #popup_load_message { position: absolute; z-index: 1050; background: var(--nsn-uif-redwood-color-light-neutral-0); border: 1px solid var(--nsn-uif-redwood-color-light-border-divider); border-radius: var(--nsn-uif-redwood-border-rounded-corners); box-shadow: rgba(0, 0, 0, 0.2) 0px 2px 8px 1px; }
.popup-load-title { font-size: var(--nsn-uif-redwood-font-size-body-lg); font-weight: var(--nsn-uif-redwood-font-weight-semi-bold); position: absolute; top: 50%; left: 50%; transform: translateX(-50%) translateY(-50%); animation-name: skeleton; animation-iteration-count: infinite; animation-direction: alternate; animation-duration: 1.5s; }
.uir-shuttle-panes-tr .popupheadernosort { line-height: 28px; }
.uir-shuttle-panes-tr .popupheadernosort:nth-child(2)::before { content: ""; width: 16px; }
.uir-shuttle-panes-tr #inner_popup_div { margin: 0 var(--nsn-uif-redwood-spacing-2-x) 0 var(--nsn-uif-redwood-spacing-4-x); border: 1px solid var(--nsn-uif-redwood-color-light-border-divider) !important; width: auto !important; }
.uir-shuttle-panes-tr #inner_popup_div tr td:first-child { display: none; }
.uir-shuttle-panes-tr #inner_popup_div tr td a { gap: var(--nsn-uif-redwood-spacing-2-x); }
.uir-shuttle-panes-tr #inner_popup_div tr td a::before { content: ""; display: block; background-size: contain; background-image: url("uiredwood/img/icon/arrow-right-alt.svg"); background-repeat: no-repeat; width: 16px; height: 16px; }
.uir-shuttle-panes-tr #popup_select_list { margin: 0 var(--nsn-uif-redwood-spacing-4-x) 0 var(--nsn-uif-redwood-spacing-2-x); height: 100%; border: 1px solid var(--nsn-uif-redwood-color-light-border-divider) !important; width: auto !important; }
.uir-shuttle-panes-tr #popup_select_list .uir-popup-x-icon { display: block; background-image: url("uiredwood/img/icon/close.svg"); background-size: contain; height: 16px; width: 16px; }
.uir-shuttle-panes-tr .multiselecttr { font-size: var(--nsn-uif-redwood-font-size-body-sm); height: var(--nsn-uif-redwood-md-spacing-8-x); border-top: 1px solid transparent; border-bottom: 1px solid transparent; }
.uir-shuttle-panes-tr .multiselecttr td { vertical-align: middle !important; }
.uir-shuttle-panes-tr .multiselecttr td:first-child { padding: 0 var(--nsn-uif-redwood-spacing-2-x); width: 16px !important; }
.uir-shuttle-panes-tr .multiselecttr td:nth-child(2) { padding-right: var(--nsn-uif-redwood-spacing-2-x); }
.uir-shuttle-panes-tr .multiselecttr:hover { background-color: var(--nsn-uif-redwood-color-light-overlay-hover); }
.uir-shuttle-panes-tr .noselections td { font-size: var(--nsn-uif-redwood-font-size-body-sm); height: var(--nsn-uif-redwood-md-spacing-8-x); padding: 0 var(--nsn-uif-redwood-md-spacing-4-x) 0 0; border-top: 1px solid transparent; border-bottom: 1px solid transparent; text-align: center; color: var(--nsn-uif-redwood-color-light-text-secondary); }
#popup_outerdiv .tabBnt, #popup_outerdiv .tabBnt_sel { position: relative; display: inline-flex; align-items: center; height: var(--nsn-uif-redwood-md-spacing-9-x); font-size: var(--nsn-uif-redwood-font-size-body-sm); font-weight: var(--nsn-uif-redwood-font-weight-semi-bold); border-radius: var(--nsn-uif-redwood-border-rounded-corners-mid); cursor: pointer; border-width: 1px; border-style: solid; border-image: initial; background-color: transparent; white-space: nowrap; text-decoration: none; color: var(--nsn-uif-redwood-color-light-text-primary); fill: var(--nsn-uif-redwood-color-light-text-primary); border-color: var(--nsn-uif-redwood-color-light-border-enabled); padding: 0 var(--nsn-uif-redwood-md-spacing-4-x); }
#popup_outerdiv .tabBnt::before, #popup_outerdiv .tabBnt_sel::before { content: ""; position: absolute; background-color: transparent; width: 100%; height: 100%; z-index: 1; top: -1px; left: -1px; box-sizing: content-box; border: 1px solid transparent; border-radius: var(--nsn-uif-redwood-border-rounded-corners-mid); }
#popup_outerdiv .tabBnt:hover::before, #popup_outerdiv .tabBnt_sel:hover::before { background-color: var(--nsn-uif-redwood-color-light-overlay-hover); }
#popup_outerdiv .tabBnt:active::before, #popup_outerdiv .tabBnt_sel:active::before { background-color: var(--nsn-uif-redwood-color-light-overlay-active); }
#inner_popup_div table, #inner_popup_div table tr, #inner_popup_div table tr td, #popup_select_list table { padding: 0px; overflow: hidden; text-overflow: ellipsis; background: white; vertical-align: middle; border-spacing: 0px; }
.ns-chart-frame { height: 100%; }
.ns-chart-frame > #body { flex-grow: 1; min-height: 0px; }
.ns-chart-control-panel-wrapper { display: flex; align-items: center; flex-wrap: wrap; flex-grow: 0; gap: 16px; margin-bottom: 16px; }
.ns-chart-control-area--dropdown { order: -1; }
.ns-chart-control-area--dropdown .uir-field-wrapper { margin-top: 0px !important; }
.ns-chart-control-area { display: flex; }
.ns-chart-control-area--dropdown { flex-grow: 1; }
.ns-chart-control-area--icons { border: 1px solid var(--uif-redwood-color-light-border-divider); border-radius: var(--nsn-uif-redwood-border-rounded-corners-mid); overflow: hidden; }
.ns-chart-icon { width: 36px; height: 26px; padding: 3px 8px; cursor: pointer; background-color: rgb(233, 231, 230); }
.ns-chart-icon::before { content: ""; display: block; width: 20px; height: 20px; background-color: var(--nsn-uif-redwood-color-light-text-secondary); mask-size: 20px 20px; }
.ns-chart-icon:hover::before { background-color: rgb(22, 21, 19); }
.ns-chart-icon:not(:first-child) { border-left: 1px solid var(--uif-redwood-color-light-border-divider); }
.ns-chart-icon-selected { background-color: transparent; cursor: auto !important; }
.ns-chart-icon-selected::before { background-color: rgb(22, 21, 19) !important; }
.ns-chart-icon-area::before { mask: url("uiredwood/img/icon/chart-area.svg"); }
.ns-chart-icon-line::before { mask: url("uiredwood/img/icon/chart-line.svg"); }
.ns-chart-icon-column::before { mask: url("uiredwood/img/icon/chart-bar-v.svg"); }
.ns-chart-icon-bar::before { mask: url("uiredwood/img/icon/chart-bar-h.svg"); }
.ns-chart-icon-pie::before { mask: url("uiredwood/img/icon/chart-pie.svg"); }
.ns-chart-icon-cont::before, .ns-chart-icon-continuous::before { mask: url("uiredwood/img/icon/chart-continue.svg"); }
.ns-chart-icon-comp::before, .ns-chart-icon-comparison::before { mask: url("uiredwood/img/icon/chart-side-by-side.svg"); }
.ns-chart-graph { flex-grow: 1; }
.ns-chart-export-button { margin-top: var(--nsn-uif-redwood-spacing-4-x); align-self: end; }
.bundlelist_imgaction { display: inline-flex; flex-shrink: 0; width: 20px; height: 20px; background-image: url("uiredwood/img/list/settings.svg"); background-size: contain; cursor: pointer; }
#noresultsmsgid { padding: var(--nsn-uif-redwood-spacing-2-x) !important; }
.custFLH_Buttons .uir-button { margin-right: var(--nsn-uif-redwood-md-spacing-3-x); }
.custFlhEditForm .fullWidth > span { flex-grow: 1; }
