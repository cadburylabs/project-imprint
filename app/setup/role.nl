.rptfooter { position: absolute; bottom: 0px; background-color: var(--nsn-uif-redwood-color-light-neutral-30); overflow-x: auto; }
.rptfooterfilter { width: 100%; padding: var(--nsn-uif-redwood-spacing-3-x) var(--nsn-uif-redwood-spacing-6-x); border-bottom: 1px solid var(--nsn-uif-redwood-color-light-border-divider); }
