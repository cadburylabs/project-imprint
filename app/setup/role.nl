.ns-dashboard-content-manager { border-radius: var(--nsn-uif-redwood-border-rounded-corners-mid); display: none; margin-bottom: 8px; clear: both; }
.ns-dashboard-content-manager h2 { display: flex; align-items: center; background-color: var(--nsn-uif-redwood-color-light-brand-130); height: 36px; padding: 0 var(--nsn-uif-redwood-size-2-xs) 0 var(--nsn-uif-redwood-size-s); border-radius: var(--nsn-uif-redwood-border-rounded-corners-mid) var(--nsn-uif-redwood-border-rounded-corners-mid) 0 0; margin: 0px; }
.ns-dashboard-content-manager h2 span { flex-grow: 1; line-height: 20px; overflow: hidden; font-weight: var(--nsn-uif-redwood-font-weight-bold); font-size: var(--nsn-uif-redwood-font-size-body-md); color: var(--nsn-uif-redwood-color-dark-text-primary); }
.ns-dashboard-content-manager h2 .ns-close-content-manager { font-weight: var(--nsn-uif-redwood-font-weight-regular); font-size: var(--nsn-uif-redwood-font-size-body-xl); color: var(--nsn-uif-redwood-color-dark-text-primary); border-radius: var(--nsn-uif-redwood-border-rounded-corners-mid); background-color: transparent; border: 0px; }
.ns-dashboard-content-manager h2 .ns-close-content-manager:hover, .ns-dashboard-content-manager h2 .ns-close-content-manager:focus { cursor: pointer; background-color: var(--nsn-uif-redwood-color-light-overlay-hover-inverse); }
.ns-dashboard-content-manager .ns-content-selection { display: flex; background-color: var(--nsn-uif-redwood-color-light-neutral-20); height: 240px; max-height: 240px; position: relative; border-left: 1px solid var(--nsn-uif-redwood-color-light-border-divider); border-right: 1px solid var(--nsn-uif-redwood-color-light-border-divider); border-bottom: 1px solid var(--nsn-uif-redwood-color-light-border-divider); border-radius: 0 0 var(--nsn-uif-redwood-border-rounded-corners-mid) var(--nsn-uif-redwood-border-rounded-corners-mid); }
.ns-dashboard-content-manager .ns-group-selection { display: flex; flex-shrink: 0; width: 300px; border-bottom-left-radius: var(--nsn-uif-redwood-border-rounded-corners-mid); }
.ns-dashboard-content-manager .ns-group-selection ul { display: flex; flex-direction: column; flex-grow: 1; padding: 0px; margin: 0px; list-style-type: none; background-color: var(--nsn-uif-redwood-color-light-neutral-30); border-bottom-left-radius: var(--nsn-uif-redwood-border-rounded-corners-mid); }
.ns-dashboard-content-manager .ns-group-selection ul li { display: flex; flex-grow: 1; align-items: center; color: var(--nsn-uif-redwood-color-light-text-primary); font-weight: var(--nsn-uif-redwood-font-weight-semi-bold); font-size: var(--nsn-uif-redwood-font-size-body-md); padding: var(--nsn-uif-redwood-size-2-xs) var(--nsn-uif-redwood-size-m); }
.ns-dashboard-content-manager .ns-group-selection ul li:hover { cursor: pointer; }
.ns-dashboard-content-manager .ns-group-selection ul li + li { border-top: 1px solid var(--nsn-uif-redwood-color-light-border-divider); }
.ns-dashboard-content-manager .ns-group-selection ul .ns-active-group { position: relative; background-color: var(--nsn-uif-redwood-color-light-neutral-20); }
.ns-dashboard-content-manager .ns-group-selection ul .ns-active-group::before { position: absolute; content: ""; height: 100%; top: 0px; left: 0px; border-left: 5px solid var(--nsn-uif-redwood-color-light-border-selected); }
.ns-dashboard-content-manager .ns-group-selection .ns-group:last-child { border-bottom-left-radius: var(--nsn-uif-redwood-border-rounded-corners-mid); }
.ns-dashboard-content-manager .ns-personalize-loading .ns-portlet-subelement-loader { background-color: var(--nsn-uif-redwood-color-light-neutral-20); }
.ns-dashboard-content-manager .ns-portlet-selection { display: flex; overflow: hidden; padding: 0 var(--nsn-uif-redwood-size-l); position: relative; align-items: center; width: 100%; }
.ns-dashboard-content-manager .ns-prev-portlet-selection-page, .ns-dashboard-content-manager .ns-next-portlet-selection-page { display: flex; width: var(--nsn-uif-redwood-size-l); height: 100%; border-width: medium; border-style: none; border-color: currentcolor; border-image: initial; background-color: transparent; position: absolute; justify-content: center; align-items: center; cursor: pointer; }
.ns-dashboard-content-manager .ns-prev-portlet-selection-page { left: 0px; }
.ns-dashboard-content-manager .ns-next-portlet-selection-page { right: 0px; }
.ns-dashboard-content-manager .ns-movable-content-wrapper { overflow-x: auto; scrollbar-width: none; }
.ns-dashboard-content-manager .ns-movable-content-wrapper::-webkit-scrollbar { display: none; }
.ns-dashboard-content-manager .ns-movable-content-wrapper .ns-content-manager-category-content { padding: var(--nsn-uif-redwood-size-2-xs) 0; }
.ns-dashboard-content-manager .ns-remove-portlet-drop-target { display: flex; position: absolute; left: 0px; top: 0px; width: 100%; height: 100%; background-color: var(--nsn-uif-redwood-color-light-neutral-20); opacity: 0.8; align-items: center; justify-content: center; }
.ns-dashboard-content-manager .ns-remove-portlet-drop-target.ns-portlet-cannot-be-removed .ns-content-manager-item { display: none; }
.ns-dashboard-content-manager .ns-remove-portlet-drop-target.ns-highlight { opacity: 1; border: 2px dashed var(--nsn-uif-redwood-color-light-border-enabled); border-radius: var(--nsn-uif-redwood-border-rounded-corners-mid); background-color: var(--nsn-uif-redwood-color-light-neutral-40); margin: 8px 0px 8px 32px; height: calc(100% - 16px); width: calc(100% - 64px); }
.ns-dashboard-content-manager .ns-remove-portlet-drop-target .ns-remove-portlet-drop-target-item { display: flex; flex-direction: column; align-items: center; color: var(--nsn-uif-redwood-color-light-text-primary); }
.ns-dashboard-content-manager .ns-remove-portlet-drop-target .ns-remove-portlet-drop-target-item .ns-remove-portlet-icon { font-size: 0px; background: url("uiredwood/img/icon/close.svg") center center / 24px 24px no-repeat; width: 32px; height: 32px; }
.ns-dashboard-content-manager .ns-remove-portlet-drop-target .ns-remove-portlet-drop-target-item .ns-item-title { font-weight: var(--nsn-uif-redwood-font-weight-semi-bold); font-size: var(--nsn-uif-redwood-font-size-body-sm); line-height: 16px; }
.ns-content-manager-item:not(.ns-remove-portlet-drop-target-item) { border-left: var(--nsn-uif-redwood-size-3-xs) solid var(--nsn-uif-redwood-color-light-border-selected); border-radius: var(--nsn-uif-redwood-border-rounded-corners-mid); background-color: var(--nsn-uif-redwood-color-light-neutral-0); margin: var(--nsn-uif-redwood-size-2-xs); width: 210px; height: 84px; position: relative; cursor: pointer; align-items: center; justify-content: center; flex-direction: column; display: inline-flex; }
.ns-content-manager-item:not(.ns-remove-portlet-drop-target-item):not(.ns-disabled-item):hover, .ns-content-manager-item:not(.ns-remove-portlet-drop-target-item):not(.ns-disabled-item):focus, .ns-content-manager-item.ns-content-manager-item-active:not(.ns-remove-portlet-drop-target-item):not(.ns-disabled-item) { box-shadow: var(--nsn-uif-redwood-shadow-small); }
.ns-content-manager-item:not(.ns-remove-portlet-drop-target-item):not(.ns-close-supported):not(.ns-locked-cannot-be-removed):not(.ns-disabled-item):hover .ns-badge-container, .ns-content-manager-item:not(.ns-remove-portlet-drop-target-item):not(.ns-close-supported):not(.ns-locked-cannot-be-removed):not(.ns-disabled-item):focus .ns-badge-container { display: flex; }
.ns-content-manager-item.ns-disabled-item:not(.ns-remove-portlet-drop-target-item) { cursor: default; background-color: transparent; border: 1px solid var(--nsn-uif-redwood-color-light-border-divider); }
.ns-content-manager-item.ns-disabled-item:not(.ns-remove-portlet-drop-target-item) .ns-item-title { color: var(--nsn-uif-redwood-color-light-text-secondary); }
.ns-content-manager-item:not(.ns-remove-portlet-drop-target-item) .ns-portlet-thumbnail { display: flex; position: relative; background-image: url("uiredwood/img/portleticon/general.svg"); background-size: contain; background-repeat: no-repeat; width: 32px; height: 32px; margin-bottom: var(--nsn-uif-redwood-size-3-xs); fill: var(--nsn-uif-redwood-color-light-text-primary); }
.ns-content-manager-item:not(.ns-remove-portlet-drop-target-item) .ns-item-title { text-align: center; text-overflow: ellipsis; overflow: hidden; font-weight: var(--nsn-uif-redwood-font-weight-semi-bold); font-size: var(--nsn-uif-redwood-font-size-body-sm); line-height: 16px; color: var(--nsn-uif-redwood-color-light-text-primary); }
