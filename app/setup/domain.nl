.n-f-fieldgroup-column { gap: var(--uif-redwood-size-2-xs); }
.n-f-fieldgroup-column [data-widget="Field"] { max-width: 100%; }
.n-f-group-location-top { padding: 0px; }
.n-f-actionbar { gap: var(--uif-redwood-size-s); }
.n-f-label-panel { margin-bottom: var(--uif-redwood-size-4-xs); }
.n-f-field-validityindicator--valid { display: none; gap: var(--uif-redwood-size-2-xs); }
.n-f-status-icon--invalid { fill: var(--uif-redwood-color-light-danger-120); margin: 0 var(--uif-redwood-size-2-xs); width: 16px !important; height: 16px !important; }
.n-w-form__field-label__text--mandatory::after { content: " *"; color: var(--uif-redwood-color-light-warning-90); }
.n-f-widget-builder__item-style--mandatory::after { content: "*"; color: var(--uif-redwood-color-light-warning-90); padding-left: 2px; }
.n-f-data-panel .n-f-fieldaction { min-width: 26px; height: 26px; padding: 0px !important; margin-left: var(--uif-redwood-size-2-xs) !important; }
.n-f-fieldaction--visibleondemand { visibility: hidden; }
.n-f-fieldcontainer-active .n-f-fieldaction { visibility: visible; }
.n-f-fieldcontainer--dataviewdisabled.n-f-fieldcontainer--emptyfield .n-f-fieldaction--hiddenonemptyreadonly, .n-f-fieldcontainer--dataviewdisabled .n-f-fieldaction--hiddenonreadonly { display: none; }
.n-f-associated-field-panel__multi-row { column-gap: var(--uif-redwood-size-xs) !important; }
.n-f-associated-field-panel__multi-row .n-f-field-panel:has([data-widget="TextArea"]), .n-f-associated-field-panel__multi-row .n-f-field-panel:has([data-widget="RichText"]) { min-width: fit-content; }
.n-f-popup-select-picker-view__header-filter { margin: var(--uif-redwood-size-3-xs); }
.n-f-searchlistsublist-header { margin-bottom: var(--uif-redwood-size-m); }
.n-f-field__image { max-width: 250px; }
.n-f-sublist-toolbar, .n-f-sublist-toolbar-group { gap: var(--uif-redwood-size-2-xs); }
.n-f-title-hidden { display: none; }
.n-w-datagrid__popupselect-cell .n-f-popupselect { margin: var(--uif-redwood-spacing-3-x) var(--uif-redwood-spacing-4-x); }
.n-w-datagrid__popupselect-cell .n-w-datagrid__popupselect-cell__text { margin: var(--uif-redwood-spacing-3-x) var(--uif-redwood-spacing-4-x); }
.n-f-associated-field-panel:not(.n-f-panel-horizontal-labels) [data-field-section="label"] { height: 2em; }
.n-f-associated-field-panel:not(.n-f-panel-horizontal-labels) .n-f-checkbox-field { padding-top: 2em; }
.n-f-field__text-html--view-only[data-wrap="true"] { white-space: pre-wrap; }
@keyframes pageSearchHighlight { 
  0% { outline-color: var(--uif-redwood-color-light-border-selected); }
  50% { outline-color: transparent; }
  100% { outline-color: var(--uif-redwood-color-light-border-selected); }
}
.uif-system-search__highlight, .uif-system-search__highlight[data-widget="Tab"] { outline-color: ; outline-width: ; outline-style: outset; animation: 1s ease-in-out 0s infinite normal none running pageSearchHighlight; }
.uif-system-search__highlight[data-widget="Tab"], .uif-system-search__highlight[data-widget="GridHeaderCell"] { outline-offset: -2px; }
.uif-system-search__highlight[data-widget="Button"], .uif-system-search__highlight[data-widget="MenuButton"] { outline-offset: 2px; }
.n-f-size-width__field--xsmall { width: 50px; }
.n-f-size-width__field--xsmall.n-w-form-field-checkbox { width: 100px; }
.n-f-size-width__field--xsmall[data-widget="RichTextEditor"] { width: 150px; }
.n-f-size-width__field--small { width: 100px; }
.n-f-size-width__field--small[data-widget="RichTextEditor"] { width: 150px; }
.n-f-size-width__field--medium { width: 280px; }
.n-f-size-width__field--large { width: 500px; }
.n-f-size-width__field--xlarge { width: 800px; }
.n-f-date-field { min-width: 150px; }
.n-f-size-height__field--small { height: 50px; }
.n-f-size-height__field--small[data-widget="RichTextEditor"] { height: 100px; }
.n-f-size-height__field--medium { height: 100px; }
.n-f-size-height__field--large { height: 200px; }
.n-f-size-height__field--xlarge { height: 350px; }
.n-f-size-height__field--xxlarge { height: 800px; }
.n-f-date-field { min-width: 150px; }
.n-f-sublist__datagrid .n-f-sublist-totalRow-cell { margin: var(--uif-redwood-spacing-3-x) var(--uif-redwood-spacing-4-x); }
html { --nsn-forms-outer-spacing: var(--uif-redwood-size-m); }
.n-f-actionbar [data-widget="Button"], .n-f-actionbar [data-widget="SplitButton"], .n-f-searchlistsublist-header_field, .n-f-field { margin: 0px !important; }
.uif2 {
  & [data-dragging], & [data-dragging] * {
  cursor: grabbing !important; user-select: none !important;
  & [data-drag-source] { cursor: unset !important; }
}
  & [data-drag-source] { cursor: grab !important; user-select: none; }
  & [data-forbid-drag] { cursor: auto; user-select: text; }
}
