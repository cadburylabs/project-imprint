div.sttip div.tooltip.ogl-coachmark .popover-inner .close-btn { background-image: url("data:image/svg+xml;base64,"); background-position: 50% 50%; background-repeat: no-repeat; border: 1px solid rgba(22, 21, 19, 0.5); border-radius: 4px; height: 26px; left: calc(100% - 26px); margin: 0px; position: relative; width: 24px; }
div.sttip div.tooltip.ogl-coachmark.in[class*="left"] .popover-inner .close-btn { left: auto; }
