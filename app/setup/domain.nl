dge\\n */\\n\\n\\n/* NLItemMachine.jsp (NLItemMachineScript.java) */\\n\\nfunction hasLineItemGroup(sublistId)\\n{\\n    return coreRecord.getSublistType(sublistId) != null;\\n}\\n\\nfunction getItemMachDisabled(fieldId)\\n{\\n    return nlapiGetLineItemDisabled(\u0027item\u0027, fieldId);\\n}\\n\\nfunction setItemMachDisabled(fieldId, bdisabled)\\n{\\n    if (hasItemMachField(fieldId))\\n        return nlapiSetLineItemDisabled(\u0027item\u0027, fieldId, bdisabled);\\n}\\n\\nfunction hasItemMachField(fieldId)\\n{\\n    return record.getLineItemField(\u0027item\u0027, fieldId, record.getCurrentLineItemIndex(\u0027item\u0027)) != null;\\n}\\n\\nfunction getItemMachField(fieldId)\\n{\\n    return record.getLineItemField(\u0027item\u0027, fieldId, record.getCurrentLineItemIndex(\u0027item\u0027));\\n}\\n\\nfunction getItemMachValue(fieldId)\\n{\\n    return nlapiGetCurrentLineItemValue(\u0027item\u0027, fieldId);\\n}\\n\\nfunction setItemMachValue(fieldId, value)\\n{\\n    return nlapiSetCurrentLineItemValue(\u0027item\u0027, fieldId, value, false)\\n}\\n\\nfunction getEncodedFieldPosition(sublistId, fieldId)\\n{\\n    var sublistfields = record.getAllLineItemFields(sublistId);\\n    return sublistfields.indexOf(fieldId);\\n}\\n;/**\\n * Global References\\n * coreRecord {RawRecord} - current record (see recordDefinition.js)\\n * utilityFunctions {Object} N/utilityFunction module\\n * runInternalScript {function} execute script in the internal mode\\n * dateutil {Object} N/util/date module\\n * currencyutil {Object} N/util/currencyUtility\\n * invoker {Object} N/internal/invoker\\n * remoteApi {Object} N/restricted/remoteApiBridge\\n * search {Object} N/search\\n * searchUtil {Object} N/search/searchUtil\\n */\\n\\n/** @type {RecordImplV1} - coreRecord wrapped in version one interface */\\nrecord = record;\\n\\nfunction throwUnsupportedError()\\n{\\n\\tthrow nlapiCreateError(\u0027SSS_UNSUPPORTED_METHOD\u0027, \u0027Unsupported method\u0027);\\n}\\n\\nvar wrapEmitLegacy