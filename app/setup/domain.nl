.ck-reset_all :not(.ck-reset_all-excluded *), .ck.ck-reset, .ck.ck-reset_all { overflow-wrap: break-word; background: transparent; border: 0px; box-sizing: border-box; height: auto; margin: 0px; padding: 0px; position: static; text-decoration: none; transition: none; vertical-align: middle; width: auto; }
