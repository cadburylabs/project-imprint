div.sttip div.tooltip:is(.ogl-coachmark, .ogl-instructional-tip) .popover-inner .ogl-rw-popover-content { background: none; color: rgb(0, 0, 0); font-size: 48px; font-weight: 700; line-height: normal; padding: 0px; }
div.sttip div.tooltip:is(.ogl-coachmark, .ogl-instructional-tip) .close-btn, div.sttip div.tooltip:is(.ogl-coachmark, .ogl-instructional-tip) .dragger-tip-container { background: none; }
