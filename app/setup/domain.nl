Object} N/util/currencyUtility\\n * invoker {Object} N/internal/invoker\\n * remoteApi {Object} N/restricted/remoteApiBridge\\n */\\n\\n/*\\n * Wrapper Function for global date util reference - NLCommonScripts.getDateFunctions(locale)\\n */\\nfunction addmonths(d, mtoadd) { return dateutil.addMonths(d, mtoadd); }\\nfunction adddays(d, daystoadd) { return dateutil.addDays(d, daystoadd); }\\nfunction nlapiStringToDate(d, dateformat, returnNullIfInvalid, formattype) { return stringtodate(d, dateformat, returnNullIfInvalid, formattype)};\\nfunction stringtodate(d, dateformat, returnNullIfInvalid, formattype) { return dateutil.stringToDate(d, dateformat, returnNullIfInvalid, formattype); }\\nfunction stringtotime(date, time) { return dateutil.stringToTime(date, time); }\\nfunction gettimestring(time, amvar, pmvar) { return dateutil.getTimeString(time, amvar, pmvar); }\\nfunction getdatestring(d, format) { return dateutil.getDateString(d, format); }\\nfunction getdatetimestring(date) { return dateutil.getDatetimeString(date); }\\nfunction getdatetimetzstring(date) { return dateutil.getDatetimetzString(date); }\\nfunction get_julian_date(d) { return dateutil.get_julian_date(d); }\\nfunction round_hhmm(val, round_by, direction) { return dateutil.round_hhmm(val, round_by, direction); }\\nfunction round_hhmm2(val, round_by, direction) { return dateutil.round_hhmm2(val, round_by, direction); }\\n;/**\\n * Global References\\n * coreRecord {RawRecord} current record (see recordDefinition.js)\\n * record {RecordImplV1} wrapped record in version one interface\\n * utilityFunctions {Object} N/utilityFunction module\\n * runInternalScript {function} execute script in the internal mode\\n * dateutil {Object} N/util/date module\\n * currencyutil {Object} N/util/currencyUtility\\n * invoker {Object} N/internal/invoker\\n * remoteApi {Object} N/restricted/remoteApiBridge\\n * globalScope {Object}\\n */\\n\\nvar pageInitScriptFieldId = \u0027nsapiPI\u0027,\\n        saveRecordScriptFieldId = \u0027nsapiSR\u0027,\\n        validateFieldScriptFieldId = \u0027nsapiVF\u0027,\\n        fieldChangedScriptFieldId = \u0027nsapiFC\u0027,\\n        postSourcingScriptFieldId = \u0027nsapiPS\u0027,\\n        lineInitScriptFieldId = \u0027nsapiLI\u0027,\\n        lineCommitScriptFieldId = \u0027nsapiLC\u0027,\\n        validateInsertScriptFieldId = \u0027nsapiVI\u0027,\\n        validateDeleteScriptFieldId = \u0027nsapiVD\u0027,\\n        validateLineScriptFieldId = \u0027nsapiVL\u0027,\\n        recalcScriptFieldId = \u0027nsapiRC\u0027;\\n\\nfunction NLAlert(msg, ignoreServerSide) { alert(msg) }\\n\\nfunction alert(msg)\\n{\\n  invoker(reflet, \u0027alert\u0027, [msg]);\\n}\\n\\nfunction _confirm(msg)\\n{\\n  return invoker(reflet, \u0027confirm\u0027, [msg]);\\n}\\nvar confirm = coreRecord.getIsCurrentRecord() ? globalScope.confirm : _confirm;\\n\\nfunction debug(id, msg)\\n{\\n  invoker(reflet, \u0027debug\u0027, [id, msg]);\\n}\\n\\n// convert the extended validation return value to a boolean true/false\\nvar validationResultToBoolean = function (x)\\n{\\n\\treturn x === Object(x) \u0026\u0026 x.hasOwnProperty(\u0027valid\u0027) ? !!x.valid : !!x;\\n};\\n\\n// handle the extended validation return value in a backward compatible way\\nvar handleValidationResult = function (x)\\n{\\n\\tif (x !== Object(x) || !x.hasOwnProperty(\u0027valid\u0027))\\n\\t\\treturn x;\\n\\tif (x.valid === false \u0026\u0026 x.messages \u0026\u0026 x.messages.length)\\n\\t\\talert(x.messages.join(\u0027\\\\\\\\n\u0027));\\n\\treturn x.valid;\\n};\\n\\nfunction executeScriptFromInternalField(internalFieldId, args)\\n{\\n    var scriptContent = coreRecord.doGetValue(internalFieldId);\\n    if(!utilityFunctions.isValEmpty(scriptContent))\\n        runInternalScript(scriptContent + _createArgumentsJSExpression(args));\\n}\\n\\nfunction executeValidationScriptFromInternalField(internalFieldId, args)\\n{\\n    var script = coreRecord.doGetValue(internalFieldId);\\n    var toRet = true;\\n    if(!utilityFunctions.isValEmpty(script))\\n        toRet = runInternalScriptAndReturnResult(script + _createArgumentsJSExpression(args));\\n    return toRet;\\n}\\n\\nfunction nlapiPageInit(type)\\n{\\n    executeScriptFromInternalField(pageInitScriptFieldId, [type]);\\n}\\n\\nfunction nlapiSaveRecord()\\n{\\n    return executeValidationScriptFromInternalField(saveRecordScriptFieldId, []);\\n}\\n\\nfunction nlapiValidateField(sublistId, fieldId, line, column)\\n{\\n    return executeValidationScriptFromInternalField(validateFieldScriptFieldId, [sublistId, fieldId, line, column]);\\n}\\n\\nfunction nlapiFieldChanged(sublistId, fieldId, line, column)\\n{\\n    executeScriptFromInternalField(fieldChangedScriptFieldId, [sublistId, fieldId, line, column]);\\n}\\n\\nfunction nlapiPostSourcing(sublistId, fieldId, line)\\n{\\n    executeScriptFromInternalField(postSourcingScriptFieldId, [sublistId, fieldId, line]);\\n}\\n\\nfunction nlapiLineInit(sublistId)\\n{\\n    executeScriptFromInternalField(lineInitScriptFieldId, [sublistId]);\\n}\\n\\nfunction nlapiLineCommit(sublistId, line)\\n{\\n    executeScriptFromInternalField(lineCommitScriptFieldId, [sublistId, line]);\\n}\\n\\nfunction nlapiValidateInsert(sublistId)\\n{\\n    return executeValidationScriptFromInternalField(validateInsertScriptFieldId, [sublistId]);\\n}\\n\\nfunction nlapiValidateDelete(sublistId)\\n{\\n    return executeValidationScriptFromInternalField(validateDeleteScriptFieldId, [sublistId]);\\n}\\n\\nfunction nlapiValidateLine(sublistId, allowAddLines)\\n{\\n    var script = coreRecord.doGetValue(validateLineScriptFieldId);\\n    var isValid = true;\\n    if(!utilityFunctions.isValEmpty(script))\\n        isValid = runInternalScriptAndReturnResult(script + _createArgumentsJSExpression([sublistId]));\\n\\n    if(validationResultToBoolean(isValid) \u0026\u0026 allowAddLines)\\n        isValid = runInternalScriptAndReturnResult(sublistId+\u0027ValidateMandatoryFields(\u0027+ coreRecord.getCurrentSublistIndex(sublistId)+\u0027)\u0027);\\n\\n    return isValid;\\n}\\n\\nfunction nlapiRecalc(sublistId, localRecalc, operation)\\n{\\n    if(localRecalc)\\n        coreRecord.triggerRecalcScript(sublistId, localRecalc, operation);\\n    else\\n    {\\n        operation = operation != null ? operation : \\\"commit\\\";\\n\\n        executeScriptFromInternalField(recalcScriptFieldId, [sublistId, operation]);\\n    }\\n}\\n\\nfunction enableDisabledFields() { /* Needed for calls in NLRecord */ }\\n\\n;/**\\n * Global References\\n * coreRecord {RawRecord}  current record (see recordDefinition.js)\\n * record {RecordImplV1} wrapped record in version one interface\\n * utilityFunctions {Object} N/utilityFunction module\\n * runInternalScript {function} execute script in the internal mode\\n * dateutil {Object} N/util/date module\\n * currencyutil {Object} N/util/currencyUtility\\n * invoker {Object} N/internal/invoker\\n * remoteApi {Object} N/restricted/remoteApiBridge\\n */\\n\\n\\n/* NLItemMachine.jsp (NLItemMachineScript.java) */\\n\\nfunction hasLineItemGroup(sublistId)\\n{\\n    return coreRecord.getSublistType(sublistId) != null;\\n}\\n\\nfunction getItemMachDisabled(fieldId)\\n{\\n    return nlapiGetLineItemDisabled(\u0027item\u0027, fieldId);\\n}\\n\\nfunction setItemMachDisabled(fieldId, bdisabled)\\n{\\n    if (hasItemMachField(fieldId))\\n        return nlapiSetLineItemDisabled(\u0027item\u0027, fieldId, bdisabled);\\n}\\n\\nfunction hasItemMachField(fieldId)\\n{\\n    return record.getLineItemField(\u0027item\u0027, fieldId, record.getCurrentLineItemIndex(\u0027item\u0027)) != null;\\n}\\n\\nfunction getItemMachField(fieldId)\\n{\\n    return record.getLineItemField(\u0027item\u0027, fieldId, record.getCurrentLineItemIndex(\u0027item\u0027));\\n}\\n\\nfunction getItemMachValue(fieldId)\\n{\\n    return nlapiGetCurrentLineItemValue(\u0027item\u0027, fieldId);\\n}\\n\\nfunction setItemMachValue(fieldId, value)\\n{\\n    return nlapiSetCurrentLineItemValue(\u0027item\u0027, fieldId, value, false)\\n}\\n\\nfunction getEncodedFieldPosition(sublistId, fieldId)\\n{\\n    var sublistfields = record.getAllLineItemFields(sublistId);\\n    return sublistfields.indexOf(fieldId);\\n}\\n;/**\\n * Global References\\n * coreRecord {RawRecord} - current record (see recordDefinition.js)\\n * utilityFunctions {Object} N/utilityFunction module\\n * runInternalScript {function} execute script in the internal mode\\n * dateutil {Object} N/util/date module\\n * currencyutil {Object} N/util/currencyUtility\\n * invoker {Object} N/internal/invoker\\n * remoteApi {Object} N/restricted/remoteApiBridge\\n * search {Object} N/search\\n * searchUtil {Object} N/search/searchUtil\\n */\\n\\n/** @type {RecordImplV1} - coreRecord wrapped in version one interface */\\nrecord = record;\\n\\nfunction throwUnsupportedError()\\n{\\n\\tthrow nlapiCreateError(\u0027SSS_UNSUPPORTED_METHOD\u0027, \u0027Unsupported method\u0027);\\n}\\n\\nvar wrapEmitLegacyError = record.nlobjects.nlobjErrorWrapper.wrapEmitLegacyError;\\nvar _legacyAssertTrue = wrapEmitLegacyError(utilityFunctions.assertTrue);\\nvar _legacyCheckArgs = wrapEmitLegacyError(utilityFunctions.checkArgs);\\n\\n\\nfunction isTextOrCDATANode(node)\\n{\\n\\treturn node.nodeType === 3 || node.nodeType === 4;\\n}\\n\\nfunction _rs_getXMLValue(node )\\n{\\n\\tvar isAttr = node.nodeType === 2;\\n\\tvar isDocument = node.nodeType === 9;\\n\\tif (isTextOrCDATANode(node))\\n\\t\\treturn node.nodeValue;\\n\\tif (isAttr)\\n\\t\\treturn node.value;\\n\\tif (isDocument)\\n\\t\\tnode = node.documentElement;\\n\\n\\tvar value = null;\\n\\tvar elems = node.childNodes;\\n\\tfor ( var i = 0; i \u003C elems.length; i++ )\\n\\t{\\n\\t\\tvar elem = elems[ i ];\\n\\t\\tif (isTextOrCDATANode(elem))\\n\\t\\t{\\n\\t\\t\\tif (value == null)\\n\\t\\t\\t\\tvalue = elem.nodeValue;\\n\\t\\t\\telse\\n\\t\\t\\t\\tvalue += elem.nodeValue;\\n\\t\\t}\\n\\t}\\n\\treturn value;\\n}\\n\\n/* undocumented inaccessible APIs */\\nfunction getV1ApiBlackList(){\\n    return [\\n        \u0027NLAlert\u0027, \u0027adddays\u0027, \u0027addmonths\u0027, /*\u0027alert\u0027,*/ \u0027amount_string\u0027, /*\u0027confirm\u0027,*/ /*\u0027debug\u0027,*/ \u0027enableDisabledFields\u0027,\\n        \u0027executeScriptFromInternalField\u0027, \u0027executeValidationScriptFromInternalField\u0027, \u0027fieldChangedScriptFieldId\u0027,\\n        \u0027format_currency\u0027, \u0027format_currency2\u0027, \u0027format_percent\u0027, \u0027format_rate\u0027, \u0027getEncodedFieldPosition\u0027,\\n        \u0027getItemMachDisabled\u0027, \u0027getItemMachField\u0027, \u0027getItemMachValue\u0027, \u0027get_julian_date\u0027, \u0027get_precision\u0027,\\n        \u0027getdatestring\u0027, \u0027getdatetimestring\u0027, \u0027getdatetimetzstring\u0027, \u0027gettimestring\u0027, \u0027hasItemMachField\u0027,\\n        \u0027hasLineItemGroup\u0027, \u0027lineCommitScriptFieldId\u0027, \u0027lineInitScriptFieldId\u0027,\\n        \u0027nlapiCalculateTax\u0027, \u0027nlapiChangeCall\u0027, \u0027nlapiCreateLineItemSubrecord\u0027, \u0027nlapiEditLineItemSubrecord\u0027,\\n        \u0027nlapiFieldChanged\u0027, \u0027nlapiFireLineItemOnChange\u0027, \u0027nlapiFireOnChange\u0027, \u0027nlapiGetFieldDisabled\u0027, \u0027nlapiGetFieldLabel\u0027,\\n        \u0027nlapiGetFieldMandatory\u0027, \u0027nlapiGetFieldReadOnly\u0027, \u0027nlapiGetLineItemDisabled\u0027,\\n        \u0027nlapiGetLineItemLabel\u0027, \u0027nlapiGetLineItemMandatory\u0027, \u0027nlapiGetLineItemTotal\u0027, \u0027nlapiGetNewRecord\u0027, \u0027nlapiGetOldRecord\u0027, \u0027nlapiGetSearchColumns\u0027,\\n        \u0027nlapiInsertOption\u0027, \u0027nlapiLineCommit\u0027, \u0027nlapiLineInit\u0027, \u0027nlapiLoadCurrentLineItemSubrecord\u0027,\\n        \u0027nlapiLoadLineItemSubrecord\u0027, \u0027nlapiLoadSubrecord\u0027, \u0027nlapiLocalCall\u0027, \u0027nlapiNanoTime\u0027, \u0027nlapiPageInit\u0027,\\n        \u0027nlapiPostDeleteLine\u0027, \u0027nlapiPostSourcing\u0027, \u0027nlapiRecalc\u0027, \u0027nlapiRemoveOption\u0027, \u0027nlapiSaveRecord\u0027, \u0027nlapiServerCall\u0027,\\n        \u0027nlapiSetCurrentLineItemSelectValue\u0027, \u0027nlapiSetFieldReadOnly\u0027, \u0027nlapiSetFieldVisibility\u0027, \u0027nlapiSetLineItemDisabled\u0027,\\n        \u0027nlapiSetLineItemDisplay\u0027, \u0027nlapiSetLineItemLabel\u0027, \u0027nlapiSetLineItemMandatory\u0027, \u0027nlapiSetLineItemTotal\u0027,\\n        \u0027nlapiSetSelectValue\u0027, \u0027nlapiShowSaveConfirmation\u0027, \u0027nlapiSourceField\u0027, \u0027nlapiSourceLineItemField\u0027,\\n        \u0027nlapiValidateDelete\u0027, \u0027nlapiValidateField\u0027, \u0027nlapiValidateInsert\u0027, \u0027nlapiValidateLine\u0027,\\n        \u0027pad_decimal_places\u0027, \u0027pad_to_atleast_two_decimal_places\u0027, \u0027pageInitScriptFieldId\u0027, \u0027postSourcingScriptFieldId\u0027,\\n        \u0027process_currency_field_value\u0027, \u0027recalcScriptFieldId\u0027, \u0027round_currency\u0027, \u0027round_float\u0027, \u0027round_float_to_n_places\u0027,\\n        \u0027saveRecordScriptFieldId\u0027, \u0027setItemMachDisabled\u0027, \u0027setItemMachValue\u0027, \u0027stringtodate\u0027, \u0027stringtotime\u0027,\\n        \u0027validateDeleteScriptFieldId\u0027, \u0027validateFieldScriptFieldId\u0027, \u0027validateInsertScriptFieldId\u0027, \u0027validateLineScriptFieldId\u0027,\\n        \u0027handleValidationResult\u0027, \u0027validationResultToBoolean\u0027\\n    ];\\n}\\n\\n/* undocumented accessible APIs */\\nfunction getV1ApiGrayList(){\\n    return {\\n\\t    nlapiGetSubList : nlapiGetSubList,\\n\\t    workflow_trigger: (typeof workflow_trigger === \u0027function\u0027 ? workflow_trigger : undefined),\\n\\t    rateSlaveCondition: (typeof rateSlaveCondition === \u0027function\u0027 ? rateSlaveCondition : undefined)\\n    };\\n}\\n\\n/* documented accessible APIs */\\nfunction getV1ApiWhiteList(){\\n    return {\\n        arrayIndexOf: utilityFunctions.arrayIndexOf,\\n        isValEmpty: utilityFunctions.isValEmpty,\\n        nlapiAddDays: nlapiAddDays,\\n        nlapiAddMonths: nlapiAddMonths,\\n        nlapiAttachRecord: nlapiAttachRecord,\\n        nlapiCancelLineItem: nlapiCancelLineItem,\\n        nlapiCommitLineItem: nlapiCommitLineItem,\\n        nlapiCopyRecord: nlapiCopyRecord,\\n        nlapiCreateAssistant: nlapiCreateAssistant,\\n        nlapiCreateCSVImport: nlapiCreateCSVImport,\\n        nlapiCreateCurrentLineItemSubrecord: nlapiCreateCurrentLineItemSubrecord,\\n        nlapiCreateError: nlapiCreateError,\\n        nlapiCreateFile: nlapiCreateFile,\\n        nlapiCreateForm: nlapiCreateForm,\\n        nlapiCreateList: nlapiCreateList,\\n        nlapiCreateRecord: nlapiCreateRecord,\\n        nlapiCreateReportDefinition: nlapiCreateReportDefinition,\\n        nlapiCreateReportForm: nlapiCreateReportForm,\\n        nlapiCreateSearch: nlapiCreateSearch,\\n        nlapiCreateSubrecord: nlapiCreateSubrecord,\\n        nlapiCreateTemplateRenderer: nlapiCreateTemplateRenderer,\\n        nlapiDateToString: nlapiDateToString,\\n        nlapiDecrypt: nlapiDecrypt,\\n        nlapiDeleteFile: nlapiDeleteFile,\\n        nlapiDeleteRecord: nlapiDeleteRecord,\\n        nlapiDetachRecord: nlapiDetachRecord,\\n        nlapiDisableField: nlapiDisableField,\\n        nlapiDisableLineItemField: nlapiDisableLineItemField,\\n        nlapiEditCurrentLineItemSubrecord: nlapiEditCurrentLineItemSubrecord,\\n        nlapiEditSubrecord: nlapiEditSubrecord,\\n        nlapiEncrypt: nlapiEncrypt,\\n        nlapiEscapeXML: nlapiEscapeXML,\\n        nlapiExchangeRate: nlapiExchangeRate,\\n        nlapiFindLineItemMatrixValue: nlapiFindLineItemMatrixValue,\\n        nlapiFindLineItemValue: nlapiFindLineItemValue,\\n        nlapiFormatCurrency: nlapiFormatCurrency,\\n        nlapiGetContext: nlapiGetContext,\\n        nlapiGetCurrentLineItemDateTimeValue: nlapiGetCurrentLineItemDateTimeValue,\\n        nlapiGetCurrentLineIt