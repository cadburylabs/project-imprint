div.sttip div.tooltip .popover-inner { border: 1px solid rgb(212, 207, 202); box-shadow: rgba(0, 0, 0, 0.2) 0px 6px 12px; color: rgb(0, 0, 0); font-family: "Helvetica Neue", Helvetica, Arial, sans-serif; font-size: 16px; outline: none; text-shadow: none; transition: 0.3s cubic-bezier(0.25, 0.8, 0.25, 1); }
