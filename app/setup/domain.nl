.n-session-popup { font-size: 12px; }
.n-session-popup__content { padding: 20px 15px 10px; }
.n-session-popup__body { width: 250px; flex-grow: 1; }
.n-session-popup__image { width: 50px; height: 50px; margin-right: 15px; flex-shrink: 0; }
.n-session-popup__title { font-weight: bold; padding-bottom: 15px; }
.n-session-popup__button { align-self: flex-start; margin-left: 0px !important; margin-top: 15px !important; }
.n-session-popup__inactive-html-body > :not(.n-session-popup) { filter: blur(4px); }
.n-commerce-sa-form { padding: var(--nsn-uif-redwood-size-s); font-size: var(--nsn-uif-redwood-font-size-body-md); }
.n-commerce-sa-form .block-label { font-size: 16px; margin-bottom: var(--uif-redwood-size-2-xs); }
.n-commerce-sa-form__domainselector { margin-bottom: var(--uif-redwood-size-l); }
.n-commerce-sa-form__domainselector__shuttle { height: 300px; }
.n-commerce-sa-form__domainselector__shuttle .n-w-shuttleui__panel { min-width: 360px; }
.n-commerce-sa-form__actions { margin-bottom: var(--uif-redwood-size-l); }
.n-commerce-sa-form__pathlist { min-width: 250px; min-height: 70px; margin-bottom: var(--uif-redwood-size-2-xs) !important; }
.n-commerce-sa-list { padding: 0 var(--uif-redwood-size-s) var(--uif-redwood-size-m) var(--uif-redwood-size-s); font-size: var(--nsn-uif-redwood-font-size-body-md); width: 1420px; }
.n-commerce-sa-list__toolbar { height: 46px; }
.n-commerce-sa-list__filter { border: 2px solid var(--nsn-uif-redwood-color-light-border-divider); border-radius: var(--nsn-uif-redwood-border-rounded-corners); }
.n-commerce-sa-list__filter[data-suspended="true"] { width: 1050px; height: 250px; }
.n-commerce-sa-list__filter .filter-grid { margin-top: var(--uif-redwood-size-2-xs); align-items: flex-start; }
.n-commerce-sa-list__filter .filter-grid .datetime-panel .n-w-grid-panel__child { margin-bottom: var(--uif-redwood-size-2-xs); }
.n-commerce-sa-list__filter .filter-grid .field-label { margin: 0 var(--uif-redwood-size-3-xs); }
.n-commerce-sa-list__filter .filter-grid .domain-select { min-height: 120px; max-height: 200px; }
.n-commerce-sa-list__filter .filter-grid .quickoptions [data-widget="Button"] { margin: var(--uif-redwood-size-2-xs) var(--uif-redwood-size-s); }
.n-commerce-sa-list__filter .buttonbar { margin: var(--uif-redwood-size-s) var(--uif-redwood-size-2-xs) var(--uif-redwood-size-2-xs) var(--uif-redwood-size-2-xs); }
.n-commerce-sa-list__filter .input-invalid { box-shadow: 0 0 2px 1px var(--nsn-uif-redwood-color-light-danger-140) !important; border: 1px solid var(--nsn-uif-redwood-color-light-danger-140) !important; }
.n-commerce-sa-list__grid .path-cell { padding: var(--uif-redwood-size-2-xs); align-items: center; }
.n-commerce-sa-list__grid .status--processed, .n-commerce-sa-list__grid .status--in-progress, .n-commerce-sa-list__grid .status--failed, .n-commerce-sa-list__grid .status--suspended, .n-commerce-sa-list__grid .status--invalid-setup { display: inline-block; width: 90px; padding: 2px 5px; margin: auto; font-size: var(--nsn-uif-redwood-font-size-body-sm); font-weight: var(--nsn-uif-redwood-font-weight-semi-bold); text-align: center; text-overflow: ellipsis; overflow: hidden; white-space: nowrap; border-radius: 3px; color: rgb(255, 255, 255); }
.n-commerce-sa-list__grid .status--processed { background-color: var(--nsn-uif-redwood-color-light-success-40); }
.n-commerce-sa-list__grid .status--in-progress { background-color: var(--nsn-uif-redwood-color-light-info-40); }
.n-commerce-sa-list__grid .status--failed { background-color: var(--nsn-uif-redwood-color-light-danger-40); }
.n-commerce-sa-list__grid .status--suspended { background-color: var(--nsn-uif-redwood-color-light-neutral-40); }
.n-commerce-sa-list__grid .status--invalid-setup { background-color: var(--nsn-uif-redwood-color-light-warning-40); }
.n-commerce-sa-list .n-commerce-sa-list__filter + .n-commerce-sa-list__grid { margin-top: var(--uif-redwood-size-m); }
.insightpanel-contentpanel { overflow-x: hidden; padding: var(--uif-redwood-size-xs) 0; transition: width 1s ease-in-out, visibility 1s ease-in-out; }
.insightpanel-contentpanel.insightpanel-contentpanel_collapsed { width: 1px; min-width: 1px; visibility: hidden; }
.insightpanel-contentpanel.insightpanel-contentpanel_expanded { width: 350px; }
.insightpanel-contentpanel .insightpanel-insight_group--subTitle { text-align: center; }
.insightpanel-contentpanel .insightpanel-insight { transition: opacity 2s ease-in-out; background-color: white; margin: var(--uif-redwood-size-xs); padding: var(--uif-redwood-size-xs); min-width: calc(350px - 2 * var(--uif-redwood-size-xs)); }
.insightpanel-contentpanel .insightpanel-insight.inactive { opacity: 0; }
.insightpanel-contentpanel .insightpanel-insight.active { opacity: 1; }
.insightpanel-contentpanel .insightpanel-insight .insightpanel-insight_title { margin-top: 0px; }
.ck-hidden { display: none !important; }
:root { --ck-z-default: 1; --ck-z-panel: calc(var(--ck-z-default) + 999); --ck-z-dialog: 9999; }
.ck-transitions-disabled, .ck-transitions-disabled * { transition: none !important; }
:root { --ck-powered-by-line-height: 10px; --ck-powered-by-padding-vertical: 2px; --ck-powered-by-padding-horizontal: 4px; --ck-powered-by-text-color: #4f4f4f; --ck-powered-by-border-radius: var(--ck-border-radius); --ck-powered-by-background: #fff; --ck-powered-by-border-color: var(--ck-color-focus-border); }
.ck.ck-balloon-panel.ck-powered-by-balloon { --ck-border-radius: var(--ck-powered-by-border-radius); background: var(--ck-powered-by-background); box-shadow: none; min-height: unset; z-index: calc(var(--ck-z-panel) - 1); }
.ck.ck-balloon-panel.ck-powered-by-balloon .ck.ck-powered-by { line-height: var(--ck-powered-by-line-height); }
.ck.ck-balloon-panel.ck-powered-by-balloon .ck.ck-powered-by a { align-items: center; cursor: pointer; display: flex; filter: grayscale(80%); line-height: var(--ck-powered-by-line-height); opacity: 0.66; padding: var(--ck-powered-by-padding-vertical) var(--ck-powered-by-padding-horizontal); }
.ck.ck-balloon-panel.ck-powered-by-balloon .ck.ck-powered-by .ck-powered-by__label { color: var(--ck-powered-by-text-color); cursor: pointer; font-size: 7.5px; font-weight: 700; letter-spacing: -0.2px; line-height: normal; margin-right: 4px; padding-left: 2px; text-transform: uppercase; }
.ck.ck-balloon-panel.ck-powered-by-balloon .ck.ck-powered-by .ck-icon { cursor: pointer; display: block; }
.ck.ck-balloon-panel.ck-powered-by-balloon .ck.ck-powered-by:hover a { filter: grayscale(0); opacity: 1; }
.ck.ck-balloon-panel.ck-powered-by-balloon[class*="position_inside"] { border-color: transparent; }
.ck.ck-balloon-panel.ck-powered-by-balloon[class*="position_border"] { border-top-style: ; border-top-width: ; border-right-style: ; border-right-width: ; border-bottom-style: ; border-bottom-width: ; border-left-style: ; border-left-width: ; border-image-source: ; border-image-slice: ; border-image-width: ; border-image-outset: ; border-image-repeat: ; border-color: var(--ck-powered-by-border-color); }
