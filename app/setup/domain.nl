eTimeValue,\\n        nlapiGetLineItemField: nlapiGetLineItemField,\\n        nlapiGetLineItemMatrixField: nlapiGetLineItemMatrixField,\\n        nlapiGetLineItemMatrixValue: nlapiGetLineItemMatrixValue,\\n        nlapiGetLineItemText: nlapiGetLineItemText,\\n        nlapiGetLineItemTexts: nlapiGetLineItemTexts,\\n        nlapiGetLineItemValue: nlapiGetLineItemValue,\\n        nlapiGetLineItemValues: nlapiGetLineItemValues,\\n        nlapiGetLocation: nlapiGetLocation,\\n        nlapiGetLogin: nlapiGetLogin,\\n        nlapiGetMatrixCount: nlapiGetMatrixCount,\\n        nlapiGetMatrixField: nlapiGetMatrixField,\\n        nlapiGetMatrixValue: nlapiGetMatrixValue,\\n        nlapiGetRecordId: nlapiGetRecordId,\\n        nlapiGetRecordType: nlapiGetRecordType,\\n        nlapiGetRole: nlapiGetRole,\\n        nlapiGetSubsidiary: nlapiGetSubsidiary,\\n        nlapiGetUser: nlapiGetUser,\\n        nlapiInitiateWorkflow: nlapiInitiateWorkflow,\\n        nlapiInsertLineItem: nlapiInsertLineItem,\\n        nlapiInsertLineItemOption: nlapiInsertLineItemOption,\\n        nlapiInsertSelectOption: nlapiInsertSelectOption,\\n        nlapiIsLineItemChanged: nlapiIsLineItemChanged,\\n        nlapiLoadFile: nlapiLoadFile,\\n        nlapiLoadRecord: nlapiLoadRecord,\\n        nlapiLoadSearch: nlapiLoadSearch,\\n        nlapiLogExecution: nlapiLogExecution,\\n        nlapiLookupField: nlapiLookupField,\\n        nlapiMergeRecord: nlapiMergeRecord,\\n        nlapiMergeTemplate: nlapiMergeTemplate,\\n        nlapiOutboundSSO: nlapiOutboundSSO,\\n        nlapiPrintRecord: nlapiPrintRecord,\\n        nlapiRefreshLineItems: nlapiRefreshLineItems,\\n        nlapiRefreshPortlet: nlapiRefreshPortlet,\\n        nlapiRemoveCurrentLineItemSubrecord: nlapiRemoveCurrentLineItemSubrecord,\\n        nlapiRemoveLineItem: nlapiRemoveLineItem,\\n        nlapiRemoveLineItemOption: nlapiRemoveLineItemOption,\\n        nlapiRemoveSelectOption: nlapiRemoveSelectOption,\\n        nlapiRemoveSubrecord: nlapiRemoveSubrecord,\\n        nlapiRequestURL: nlapiRequestURL,\\n        nlapiRequestURLWithCredentials: nlapiRequestURLWithCredentials,\\n        nlapiResizePortlet: nlapiResizePortlet,\\n        nlapiResolveURL: nlapiResolveURL,\\n        nlapiScheduleScript: nlapiScheduleScript,\\n        nlapiSearchDuplicate: nlapiSearchDuplicate,\\n        nlapiSearchGlobal: nlapiSearchGlobal,\\n        nlapiSearchRecord: nlapiSearchRecord,\\n        nlapiSelectLineItem: nlapiSelectLineItem,\\n        nlapiSelectNewLineItem: nlapiSelectNewLineItem,\\n        nlapiSelectNode: nlapiSelectNode,\\n        nlapiSelectNodes: nlapiSelectNodes,\\n        nlapiSelectValue: nlapiSelectValue,\\n        nlapiSelectValues: nlapiSelectValues,\\n        nlapiSendCampaignEmail: nlapiSendCampaignEmail,\\n        nlapiSendEmail: nlapiSendEmail,\\n        nlapiSendFax: nlapiSendFax,\\n        nlapiSetCurrentLineItemDateTimeValue: nlapiSetCurrentLineItemDateTimeValue,\\n        nlapiSetCurrentLineItemMatrixValue: nlapiSetCurrentLineItemMatrixValue,\\n        nlapiSetCurrentLineItemText: nlapiSetCurrentLineItemText,\\n        nlapiSetCurrentLineItemValue: nlapiSetCurrentLineItemValue,\\n        nlapiSetCurrentLineItemValues: nlapiSetCurrentLineItemValues,\\n        nlapiSetDateTimeValue: nlapiSetDateTimeValue,\\n        nlapiSetFieldDisabled: nlapiSetFieldDisabled,\\n        nlapiSetFieldDisplay: nlapiSetFieldDisplay,\\n        nlapiSetFieldLabel: nlapiSetFieldLabel,\\n        nlapiSetFieldMandatory: nlapiSetFieldMandatory,\\n        nlapiSetFieldText: nlapiSetFieldText,\\n        nlapiSetFieldTexts: nlapiSetFieldTexts,\\n        nlapiSetFieldValue: nlapiSetFieldValue,\\n        nlapiSetFieldValues: nlapiSetFieldValues,\\n        nlapiSetLineItemDateTimeValue: nlapiSetLineItemDateTimeValue,\\n        nlapiSetLineItemMatrixValue: nlapiSetLineItemMatrixValue,\\n        nlapiSetLineItemValue: nlapiSetLineItemValue,\\n        nlapiSetMatrixValue: nlapiSetMatrixValue,\\n        nlapiSetRecoveryPoint: nlapiSetRecoveryPoint,\\n        nlapiSetRedirectURL: nlapiSetRedirectURL,\\n        nlapiStringToDate: nlapiStringToDate,\\n        nlapiStringToXML: nlapiStringToXML,\\n        nlapiSubmitCSVImport: nlapiSubmitCSVImport,\\n        nlapiSubmitField: nlapiSubmitField,\\n        nlapiSubmitFile: nlapiSubmitFile,\\n        nlapiSubmitRecord: nlapiSubmitRecord,\\n        nlapiTransformRecord: nlapiTransformRecord,\\n        nlapiTriggerWorkflow: nlapiTriggerWorkflow,\\n        nlapiViewCurrentLineItemSubrecord: nlapiViewCurrentLineItemSubrecord,\\n        nlapiViewLineItemSubrecord: nlapiViewLineItemSubrecord,\\n        nlapiViewSubrecord: nlapiViewSubrecord,\\n        nlapiVoidTransaction: nlapiVoidTransaction,\\n        nlapiXMLToPDF: nlapiXMLToPDF,\\n        nlapiXMLToString: nlapiXMLToString,\\n        nlapiYieldScript: nlapiYieldScript,\\n        nlobjContext: nlobjContext,\\n        nlobjError: nlobjError,\\n        nlobjField: nlobjField,\\n        nlobjRecord: nlobjRecord,\\n        nlobjSearch: nlobjSearch,\\n        nlobjSearchColumn: nlobjSearchColumn,\\n        nlobjSearchFilter: nlobjSearchFilter,\\n        nlobjSearchResult: nlobjSearchResult,\\n        nlobjSearchResultSet: nlobjSearchResultSet,\\n        nlobjServerResponse: nlobjServerResponse,\\n        nlobjSublist: nlobjSublist,\\n        nullIfEmpty: nullIfEmpty,\\n        nvl: nvl\\n    };\\n}\\n\\nvar nlapiAddDays = function nlapiAddDays(d, days)\\n        {\\n            return adddays(new Date(d.getTime()), parseInt(days))\\n        },\\n        nlapiAddMonths = function nlapiAddMonths(d, months)\\n        {\\n            return addmonths(new Date(d.getTime()), parseInt(months));\\n        },\\n        nlapiAttachRecord = function nlapiAttachRecord(type, id, type2, id2, attributes) { record.nonRecordV1Functions.attachRecord(type, id, type2, id2, attributes); },\\n        nlapiCopyRecord = function nlapiCopyRecord(type, id, initializeValues) { return record.nonRecordV1Functions.copyRecord(type, id, initializeValues); },// nlapi.copyRecord\\n        nlapiCreateAssistant = function nlapiCreateAssistant() { throwUnsupportedError(); },\\n        nlapiCreateCSVImport = function nlapiCreateCSVImport() { throwUnsupportedError(); },\\n        nlapiCreateError = function nlapiCreateError(code, detail, suppressNotification)\\n        {\\n            return new nlobjError(code, detail, suppressNotification);\\n        },\\n        nlapiCreateFile = function nlapiCreateFile(name, type, contents) { throwUnsupportedError(); },// nlapi.createFile, // undefined\\n        nlapiCreateForm = function nlapiCreateForm() { throwUnsupportedError(); },\\n        nlapiCreateList = function nlapiCreateList() { throwUnsupportedError(); },\\n        nlapiCreateRecord = function nlapiCreateRecord(type, initializeValues) { return record.nonRecordV1Functions.createRecord(type, initializeValues); },// nlapi.createRecord\\n        nlapiCreateReportDefinition = function nlapiCreateReportDefinition() { throwUnsupportedError(); },\\n        nlapiCreateReportForm = function nlapiCreateReportForm() { throwUnsupportedError(); },\\n        nlapiCreateSearch = function nlapiCreateSearch(type, filters, columns)\\n        {\\n\\t        _legacyCheckArgs([type], [\u0027type\u0027], \u0027nlapiCreateSearch\u0027);\\n    \\n            var options = {};\\n            options.type = type;\\n            if (isFilterExpression(filters))\\n                options.filters = filters;\\n            else if (filters != null)\\n                options.filters = utilityFunctions.getAsArray(filters).map(unwrapV2Object);\\n            if (columns != null)\\n                options.columns = utilityFunctions.getAsArray(columns).map(unwrapV2Object);\\n    \\n            return wrapV2Search(search.create(options));\\n        },\\n        nlapiCreateTemplateRenderer = function nlapiCreateTemplateRenderer() { throwUnsupportedError(); },\\n        nlapiDateToString = function nlapiDateToString(d, formattype)\\n        {\\n            if (formattype === \u0027timeofday\u0027)\\n                return gettimestring(d);\\n            else if (formattype === \u0027datetime\u0027)\\n                return getdatetimestring(d);\\n            else if (formattype === \u0027datetimetz\u0027)\\n                return getdatetimetzstring(d);\\n            else\\n                return getdatestring(d);\\n        },\\n        nlapiDecrypt = wrapEmitLegacyError(function nlapiDecrypt(s, type, key)\\n        {\\n\\t        _legacyCheckArgs([s], [\u0027encryptedtext\u0027], \u0027nlapiDecrypt\u0027);\\n            if (type == \\\"aes\\\" || type == \\\"base64\\\" || type == \\\"xor\\\")\\n                return invoker(remoteApi, \\\"decrypt\\\", [s, type, key != null ? key : null]);\\n            return null;\\n        }),\\n        nlapiDeleteFile = function nlapiDeleteFile(id) { throwUnsupportedError(); },// nlapi.deleteFile, // undefined\\n        nlapiDeleteRecord = function nlapiDeleteRecord(type, id) {  return record.nonRecordV1Functions.deleteRecord(type, id); },// nlapi.deleteRecord\\n        nlapiDetachRecord = function nlapiDetachRecord(type, id, type2, id2, attributes) { record.nonRecordV1Functions.detachRecord(type, id, type2, id2, attributes); },\\n        nlapiDisableField = function nlapiDisableField(fldnam, val) { return nlapiSetFieldDisabled(fldnam, val); },\\n        nlapiDisableLineItemField = function nlapiDisableLineItemField(type, fldnam, val) { return nlapiSetLineItemDisabled(type, fldnam, val, null); },\\n        nlapiEncrypt = wrapEmitLegacyError(function nlapiEncrypt(s, type, key)\\n        {\\n\\t        _legacyCheckArgs([s], [\u0027cleartext\u0027], \u0027nlapiEncrypt\u0027);\\n            if (type == null)\\n                type = \\\"sha1\\\";\\n            return invoker(remoteApi, \\\"encrypt\\\", [s, type, key != null ? key : null]);\\n        }),\\n        nlapiEscapeXML = function nlapiEscapeXML(text)\\n        {\\n            if (text == null)\\n                return null;\\n\\n            text = String(text);\\n            return text.replace(/\u0026/g, \u0027\u0026amp;\u0027).replace(/\\u003c/g, \u0027\u0026lt;\u0027).replace(/\u003E/g, \u0027\u0026gt;\u0027).replace(/\u0027/g, \u0027\u0026apos;\u0027).replace(/\\\"/g, \u0027\u0026quot;\u0027);\\n        },\\n        nlapiExchangeRate = wrapEmitLegacyError(function nlapiExchangeRate(fromCurrency, toCurrency, effectiveDate)\\n        {\\n\\t        _legacyCheckArgs( [fromCurrency, toCurrency], [\u0027fromCurrency\u0027, \u0027toCurrency\u0027], \u0027nlapiExchangeRate\u0027 );\\n            effectiveDate = effectiveDate instanceof Date ? \u0027\u0027 : effectiveDate; // imitate NLAPI + nlapijsonhandler behavior\\n            return String(invoker(remoteApi, \\\"nlapiExchangeRate\\\", [fromCurrency, toCurrency, effectiveDate != null ? effectiveDate : nlapiDateToString(new Date())]));\\n        }),\\n        nlapiFormatCurrency = function nlapiFormatCurrency(str)\\n        {\\n            return format_currency(str);\\n        },\\n        nlapiGetContext = function nlapiGetContext()\\n        {\\n            if (!nlapiGetContext._context)\\n                nlapiGetContext._context = new nlobjContext(); // cache\\n            return nlapiGetContext._context;\\n        },\\n        nlobjContext = function nlobjContext()\\n        {\\n            var delegate = invoker(reflet, \\\"nlapiGetContext\\\", []);\\n            if (!delegate.constructor) // we\u0027re on server and this is a java object, return as is\\n                return delegate;\\n            var context = util.extend(this, delegate);\\n            context.getSetting = function(type, name) // same as in NLAPI.js\\n            {\\n                switch (type.toLowerCase())\\n                {\\n                    case \\\"script\\\" :\\n                        return delegate.getPreference(name);\\n                    case \\\"feature\\\" :\\n                        return delegate.getFeature(name) ? \\\"T\\\" : 