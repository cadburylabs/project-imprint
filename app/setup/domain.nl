<script type="application/json" id="data_458104322" "="">{"app":{"module":"n/ui/form/FormPage","pageExportName":"Page","translations":{"NLAlertContext.PLEASE_LOG_INTO_THE_APPLICATION_AND_OPEN_THE_HELP_WINDOW_AGAIN":"Help is unavailable because your connection has timed out.\\nPlease log in to the application and open the help window again.","NLButtonContext.NO":"No","NLAlertContext.ARE_YOU_SURE_YOU_WANT_TO_DELETE_THIS_RECORD":"Are you sure you want to delete this record?","NLPagemessageContext.INVALID_CERTIFICATE__WILDCARD_CERTIFICATES_ARE_NOT_SUPPORTED":"Invalid certificate - Wildcard certificates are not supported.","NLAlertContext.FILTER_NOT_CHANGED":"Filter not changed","NLAlertContext.HTML_DOCUMENT_MUST_END_WITH_A_HTML_TAG":"HTML document must end with a \u003C/HTML\u003E tag.","NLAlertContext.INVALID_URL_URL_MUST_START_WITH_HTTP_HTTPS_FTP_OR_FILE":"Invalid url. Url must start with http://, https://, ftp://, or file://","NLAlertContext.PLEASE_ENTER_A_VALUE_FOR_1":"Please enter a value for {1}","NLAlertContext.VALIDATION_IS_IN_PROGRESS_PLEASE_TRY_LATER":"Validation is in progress. Please try later.","NLStaticlistContext.QUARTER":"Quarter","NLPagemessageContext.LINE_REMOVED":"LINE REMOVED","NLPagemessageContext.THE_CERTIFICATE_KEY_FORMAT_IS_NOT_SUPPORTED":"The certificate key format is not supported.","NLAlertContext.NON_KATAKANA_DATA_FOUND":"A non-katakana character has been entered.","NLAlertContext.HTML_DOCUMENT_MUST_BEGIN_WITH_AN_HTML_TAG":"HTML document must begin with an \u003CHTML\u003E tag.","NLFormlabelContext.UPLOAD_CERTIFICATE":"Upload Certificate","NLPagemessageContext.CERTIFICATE_TEXT_TERMS_AND_CONDITIONS":"To provide a Secure Web Domain, Oracle-NetSuite may request, validate, and deploy a Domain Validated (DV) SSL/TLS certificate (\"certificate\") on your behalf. Your NetSuite-hosted website may be further optimized for performance using a third-party infrastructure provider.\u003Cbr/\u003E\u003Cbr/\u003EThe DV certificate for your website may be managed by Oracle-NetSuite or by the third-party provider. Regardless of which company manages the DV certificate, Oracle-NetSuite handles the domain validation with an HTTP challenge. \u003Cbr/\u003E\u003Cbr/\u003EYou have the option to upload an SSL certificate issued by a trusted Certification Authority (CA) of your choice. This certificate must be based on a Certificate Signing Request (CSR) generated either by NetSuite or the third-party provider.\u003Cbr/\u003E\u003Cbr/\u003EBy clicking \"I agree\", you acknowledge you have read these Terms and understand the limitations and your responsibilities in using this functionality. \u003Cbr/\u003E\u003Cbr/\u003E\u003Ci\u003ECopyright \u0026copy; 2019, Oracle and/or its affiliates.\u003C/i\u003E","NLPagemessageContext.UNSUPPORTED_FILE_FORMAT_UPLOAD_VALID_CERTIFICATE":"Unsupported file format. Upload valid certificate.","NLFormlabelContext.FIELD_GROUP":"Field Group","NLPagemessageContext.INVALID_ROW":"Invalid row","NLFormlabelContext.CHANGE_CERTIFICATE":"Change Certificate","NLAlertContext.INVALID_TIME_VALUE":"Invalid time value","NLPagemessageContext.LINE_CANCELED":"LINE CANCELED","NLFormlabelContext.FILTER":"Filter","NLPagemessageContext.NETSUITE_MAY_CONTACT_ME_TO_MAKE_THIS_EXPERIENCE_BETTER":"Netsuite may contact me to make this experience better.","NLFormlabelContext.CONTAINS":"Contains","NLPagemessageContext.PLEASE_RATE_YOUR_EXPERIENCE":"Please rate your experience","NLAlertContext.INVALID_NUMBER_MUST_BE_AT_LEAST_1":"Invalid number (must be at least {1})","NLPagemessageContext.WAITING_FOR_DNS_CONFIGURATION":"Waiting for DNS configuration","NLButtonContext.REMOVE":"Remove","NLButtonContext.MOVE_DOWN":"Move Down","NLPagemessageContext.YOUR_SSL_CERTIFICATE_WILL_EXPIRE_SOON":"Your SSL certificate will expire soon.","NLFormlabelContext.FIELD_ID":"Field ID","NLAlertContext.IDENTIFIERS_CAN_CONTAIN_ONLY_DIGITS_ALPHABETIC_CHARACTERS_OR__WITH_NO_SPACES":"Identifiers can contain only digits, alphabetic characters, or \\\"_\\\"