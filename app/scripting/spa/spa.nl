.ogl-rw-launcher-container, .ouc-container { background-color: rgb(255, 255, 255); margin: 0px; padding: 0px; }
.ogl-rw-widget { background-color: rgb(49, 45, 42); }
.ouc-widget { background-color: rgb(27, 59, 63); }
.ogl-rw-widget, .ouc-widget { align-items: center; display: flex; flex-direction: column; position: fixed; }
.ogl-rw-widget.horizontal, .ouc-widget.horizontal { flex-direction: row; }
.ogl-rw-widget img, .ouc-widget img { display: block; height: 20px; width: 20px; }
.ogl-rw-widget a img, .ouc-widget a img { display: block; height: 20px; margin-right: 2px; margin-top: 2px; width: 20px; }
.ogl-rw-widget.horizontal a img, .ouc-widget.horizontal a img { margin-right: 2px; margin-top: 2px; }
.ogl-rw-widget.horizontal .ogl-rw-widget--move-icon, .ouc-widget.horizontal .ouc-widget__move-icon {
  top: 0px;
  &:dir(ltr) { left: -5px; }
  &:dir(rtl) { left: 5px; }
}
.ogl-rw-widget--launch, .ouc-widget__launch { align-items: center; display: flex; height: 36px; justify-content: center; text-decoration: none; width: 36px; }
.ogl-rw-widget--launch a, .ouc-widget__launch a { border-radius: 50%; color: rgb(255, 255, 255); display: block; height: 36px; text-decoration: none; width: 36px; }
.ouc-widget__launch a:hover { background-color: rgb(50, 108, 115); }
.ogl-rw-widget--launch a:hover { background-color: rgb(92, 84, 78); }
.ogl-rw-widget.ogl-mobile .ogl-rw-widget--launch a:hover, .ouc-widget.ogl-mobile .ouc-widget__launch a:hover { background-color: unset; }
.ogl-rw-widget--launch a, .ouc-widget__launch a { display: none; }
.ogl-rw-widget--launch-loader, .ouc-widget__launch-loader { color: rgb(255, 255, 255); }
.ogl-rw-widget--launch a span, .ouc-widget__launch a span { margin: 3px 0px 0px 3px; }
.ogl-rw-widget--move, .ouc-widget__move { align-items: center; cursor: pointer; display: flex; height: 36px; justify-content: center; width: 36px; }
.ogl-rw-widget--launch-icon, .ouc-widget__launch-icon {
  background-repeat: no-repeat; height: 24px; position: relative; top: 6px; width: 24px; fill: rgb(252, 252, 252); opacity: 0.84;
  &:dir(ltr) { left: 6px; }
  &:dir(rtl) { left: -6px; }
}
.ogl-rw-widget--move-icon { fill: rgb(251, 249, 248); }
.ouc-widget__move-icon { fill: rgb(248, 247, 249); }
.ogl-rw-widget--move-icon, .ouc-widget__move-icon { background-repeat: no-repeat; height: 20px; opacity: 0.35; position: relative; top: -5px; width: 20px; }
.ogl-rw-convergence-launcher #launcher, .ou-convergence-launcher #launcher { border: 0px; height: 72px; left: 0px; position: absolute; top: 0px; width: 36px; z-index: 9998; }
.ou-convergence-launcher { background: rgb(27, 59, 63); }
.ogl-rw-convergence-launcher { background: rgb(49, 45, 42); }
.ogl-rw-convergence-launcher, .ou-convergence-launcher {
  border-radius: 18px; bottom: 50%; box-shadow: rgba(0, 0, 0, 0.4) 2px 2px 5px; box-sizing: initial; height: 72px; opacity: 1; overflow: hidden; position: fixed; right: 25px; transform: translate(0px); transition: transform 0.2s ease-in-out, opacity 0.3s ease-in-out, height 0.1s linear, width 0.1s linear; width: 36px; z-index: 2147483647;
  &:dir(rtl) { left: 25px; right: unset; }
}
.ogl-rw-convergence-launcher.ogl-mobile, .ou-convergence-launcher.ogl-mobile { bottom: 100px; }
.ogl-rw-convergence-launcher #dragger, .ou-convergence-launcher #dragger { align-items: center; background-color: initial; border: 0px; cursor: move; display: flex; height: 36px; justify-content: center; left: 0px; position: absolute; top: 37px; width: 36px; z-index: 9999; }
.ogl-rw-convergence-launcher.bottom #dragger, .ogl-rw-convergence-launcher.top #dragger, .ou-convergence-launcher.bottom #dragger, .ou-convergence-launcher.top #dragger { left: 36px; top: 0px; }
.ogl-rw-convergence-launcher.bottom, .ogl-rw-convergence-launcher.bottom #launcher, .ogl-rw-convergence-launcher.top, .ogl-rw-convergence-launcher.top #launcher, .ou-convergence-launcher.bottom, .ou-convergence-launcher.bottom #launcher, .ou-convergence-launcher.top, .ou-convergence-launcher.top #launcher { height: 36px; width: 72px; }
.ou-convergence-list { border: 0px; box-shadow: rgba(0, 0, 0, 0.3) 0px 4px 18px; height: 600px; margin-top: -300px; max-width: 90%; min-width: 340px; opacity: 0; position: fixed; top: 50%; transition: 0.2s ease-in-out; visibility: hidden; width: 400px; }
.ou-convergence-list, .ou-convergence-list.right { right: 20px; transform: translate(110%); }
.ou-convergence-list.left { left: 20px; right: 0px; transform: translate(-110%); }
.ou-convergence-list.top { transform: translateY(-110%); }
.ou-convergence-list.bottom { transform: translateY(110%); }
.ou-convergence-list.visible { opacity: 1; transform: translate(0px); visibility: visible; }
.ogl-rw-convergence-launcher.hide, .ou-convergence-launcher.hide { opacity: 0; visibility: hidden; }
.ogl-rw-help-widget-iframe {
  border: 0px; border-radius: 6px; box-shadow: rgba(0, 0, 0, 0.24) 0px 8px 16px; height: 600px; margin-top: -300px; max-width: 90%; min-width: 340px; opacity: 0; position: fixed; right: 20px; top: 50%; transform: translate(110%); transition: 0.2s ease-in-out; visibility: hidden; width: 390px; z-index: 2147483647;
  &:dir(rtl) { right: unset; }
}
@media screen and (max-width: 360px) {
  .ogl-rw-help-widget-iframe, .ou-convergence-list { min-width: unset; }
}
.ogl-rw-help-widget-iframe.right { right: 20px; transform: translate(110%); }
.ogl-rw-help-widget-iframe.left {
  left: 20px; transform: translate(-110%);
  &:dir(rtl) { right: unset; }
}
.ogl-rw-help-widget-iframe.top { transform: translateY(-110%); }
.ogl-rw-help-widget-iframe.bottom { transform: translateY(110%); }
.ogl-rw-help-widget-iframe.visible { opacity: 1; transform: translate(0px); visibility: visible; }
.ogl-disable-iframe-events-dragging { pointer-events: none; user-select: none; }
#oucModalOverlay { background-color: rgba(0, 0, 0, 0.7); inset: 0px; cursor: pointer; height: 100%; opacity: 0; position: fixed; transition: 0.2s ease-in-out; visibility: hidden; width: 100%; z-index: 2147483635; }
#oucModal.visible, #oucModalOverlay.visible, .holds-the-iframe.visible { opacity: 1; visibility: visible; }
#oucModal { background-color: rgb(255, 255, 255); border: 0px; border-radius: 5px; box-shadow: rgba(50, 50, 50, 0.4) 0px 0px 10px 5px; position: fixed; z-index: 9999; }
#oucModal, .holds-the-iframe { height: 60%; left: 20%; opacity: 0; top: 20%; transition: 0.4s ease-in-out; visibility: hidden; width: 60%; }
.holds-the-iframe { background: url("loading.gif") 50% center no-repeat; border: 0px; position: absolute; z-index: 2147483640; }
.holds-the-iframe .closeMe { color: rgb(170, 170, 170); cursor: pointer; font-size: 30px; position: absolute; right: 30px; top: 10px; z-index: 10000; }
.holds-the-iframe .closeMe:hover { color: rgb(0, 0, 0); }
.ou-convergence-loading-progress { animation: 2s linear 0s infinite normal none running spin; border-width: 16px; border-style: solid; border-color: rgb(52, 152, 219) rgb(243, 243, 243) rgb(243, 243, 243); border-image: initial; border-radius: 50%; height: 120px; margin: 0px auto; width: 120px; }
.ouc-convergence-loading-text { color: rgb(255, 255, 255); display: block; margin: 0px auto; padding: 22px; width: 190px; }
@keyframes spin { 
  0% { transform: rotate(0deg); }
  100% { transform: rotate(1turn); }
}
div.sttip .ogl-survey-tip--progress { align-items: center; display: flex; gap: 16px; justify-content: space-between; margin: 0px auto 4px; padding: 10px 0px; width: max-content; }
