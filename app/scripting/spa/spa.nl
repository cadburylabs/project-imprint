div.sttip .btn-group { position: relative; }
div.sttip .btn-group::after, div.sttip .btn-group::before { content: ""; display: table; }
div.sttip .btn-group::after { clear: both; }
div.sttip .btn-group:first-child { }
div.sttip .btn-group + .btn-group { margin-left: 5px; }
div.sttip .btn-toolbar { margin-bottom: 9px; margin-top: 9px; }
div.sttip .btn-toolbar .btn-group { display: inline-block; }
div.sttip .btn-group > .btn { border-radius: 0px; float: left; margin-left: -1px; position: relative; }
div.sttip .btn-group > .btn:first-child { margin-left: 0px; border-top-left-radius: 4px; border-bottom-left-radius: 4px; }
div.sttip .btn-group > .btn:last-child, div.sttip .btn-group > .dropdown-toggle { border-top-right-radius: 4px; border-bottom-right-radius: 4px; }
div.sttip .btn-group > .btn.large:first-child { margin-left: 0px; border-top-left-radius: 6px; border-bottom-left-radius: 6px; }
div.sttip .btn-group > .btn.large:last-child, div.sttip .btn-group > .large.dropdown-toggle { border-top-right-radius: 6px; border-bottom-right-radius: 6px; }
div.sttip .btn-group > .btn.active, div.sttip .btn-group > .btn:active, div.sttip .btn-group > .btn:focus, div.sttip .btn-group > .btn:hover { z-index: 2; }
div.sttip .btn-group .dropdown-toggle:active, div.sttip .btn-group.open .dropdown-toggle { outline: 0px; }
div.sttip .btn-group > .dropdown-toggle { box-shadow: rgba(255, 255, 255, 0.125) 1px 0px 0px inset, rgba(255, 255, 255, 0.2) 0px 1px 0px inset, rgba(0, 0, 0, 0.05) 0px 1px 2px; padding-left: 8px; padding-right: 8px; }
div.sttip .btn-group > .btn-mini.dropdown-toggle { padding-left: 5px; padding-right: 5px; }
div.sttip .btn-group > .btn-small.dropdown-toggle { }
div.sttip .btn-group > .btn-large.dropdown-toggle { padding-left: 12px; padding-right: 12px; }
div.sttip .btn-group.open .dropdown-toggle { background-image: none; box-shadow: rgba(0, 0, 0, 0.15) 0px 2px 4px inset, rgba(0, 0, 0, 0.05) 0px 1px 2px; }
div.sttip .btn-group.open .btn.dropdown-toggle { background-color: rgb(230, 230, 230); }
div.sttip .btn-group.open .btn-primary.dropdown-toggle { background-color: rgb(0, 85, 204); }
div.sttip .btn-group.open .btn-warning.dropdown-toggle { background-color: rgb(248, 148, 6); }
div.sttip .btn-group.open .btn-danger.dropdown-toggle { background-color: rgb(189, 54, 47); }
div.sttip .btn-group.open .btn-success.dropdown-toggle { background-color: rgb(81, 163, 81); }
div.sttip .btn-group.open .btn-info.dropdown-toggle { background-color: rgb(47, 150, 180); }
div.sttip .btn-group.open .btn-inverse.dropdown-toggle { background-color: rgb(34, 34, 34); }
div.sttip .btn .caret { margin-left: 0px; margin-top: 7px; }
div.sttip .btn:hover .caret, div.sttip .open.btn-group .caret { opacity: 1; }
div.sttip .btn-mini .caret { margin-top: 5px; }
div.sttip .btn-small .caret { margin-top: 6px; }
div.sttip .btn-large .caret { border-left-width: 5px; border-right-width: 5px; border-top-width: 5px; margin-top: 6px; }
div.sttip .dropup .btn-large .caret { border-bottom: 5px solid rgb(0, 0, 0); border-top: 0px; }
div.sttip .btn-danger .caret, div.sttip .btn-info .caret, div.sttip .btn-inverse .caret, div.sttip .btn-primary .caret, div.sttip .btn-success .caret, div.sttip .btn-warning .caret { border-bottom-color: rgb(255, 255, 255); border-top-color: rgb(255, 255, 255); opacity: 0.75; }
div.sttip .tooltip { display: block; font-size: 11px; opacity: 0; padding: 5px; position: absolute; visibility: visible; z-index: 1020; }
div.sttip .tooltip.in { opacity: 0.8; }
div.sttip .tooltip.top { margin-top: -2px; }
div.sttip .tooltip.right { margin-left: 2px; }
div.sttip .tooltip.bottom { margin-top: 2px; }
div.sttip .tooltip.left { margin-left: -2px; }
div.sttip .tooltip.top .tooltip-arrow { border-left: 5px solid rgba(0, 0, 0, 0); border-right: 5px solid rgba(0, 0, 0, 0); border-top: 5px solid rgb(0, 0, 0); bottom: 0px; left: 50%; margin-left: -5px; }
div.sttip .tooltip.left .tooltip-arrow { border-bottom: 5px solid rgba(0, 0, 0, 0); border-left: 5px solid rgb(0, 0, 0); border-top: 5px solid rgba(0, 0, 0, 0); margin-top: -5px; right: 0px; top: 50%; }
div.sttip .tooltip.bottom .tooltip-arrow { border-bottom: 5px solid rgb(0, 0, 0); border-left: 5px solid rgba(0, 0, 0, 0); border-right: 5px solid rgba(0, 0, 0, 0); left: 50%; margin-left: -5px; top: 0px; }
div.sttip .tooltip.right .tooltip-arrow { border-bottom: 5px solid rgba(0, 0, 0, 0); border-right: 5px solid rgb(0, 0, 0); border-top: 5px solid rgba(0, 0, 0, 0); left: 0px; margin-top: -5px; top: 50%; }
div.sttip .tooltip-inner { background-color: rgb(0, 0, 0); border-radius: 4px; color: rgb(255, 255, 255); max-width: 200px; padding: 3px 8px; text-align: center; text-decoration: none; }
div.sttip .tooltip-arrow { height: 0px; position: absolute; width: 0px; }
div.sttip .popover { display: none; left: 0px; padding: 5px; position: absolute; top: 0px; z-index: 1010; }
div.sttip .popover.top { margin-top: -5px; }
div.sttip .popover.right { margin-left: 5px; }
div.sttip .popover.bottom { margin-top: 5px; }
div.sttip .popover.left { margin-left: -5px; }
div.sttip .popover.top .arrow { border-left: 5px solid rgba(0, 0, 0, 0); border-right: 5px solid rgba(0, 0, 0, 0); border-top: 5px solid rgb(0, 0, 0); bottom: 0px; left: 50%; margin-left: -5px; }
div.sttip .popover.right .arrow { border-bottom: 5px solid rgba(0, 0, 0, 0); border-right: 5px solid rgb(0, 0, 0); border-top: 5px solid rgba(0, 0, 0, 0); left: 0px; margin-top: -5px; top: 50%; }
div.sttip .popover.bottom .arrow { border-bottom: 5px solid rgb(0, 0, 0); border-left: 5px solid rgba(0, 0, 0, 0); border-right: 5px solid rgba(0, 0, 0, 0); left: 50%; margin-left: -5px; top: 0px; }
div.sttip .popover.left .arrow { border-bottom: 5px solid rgba(0, 0, 0, 0); border-left: 5px solid rgb(0, 0, 0); border-top: 5px solid rgba(0, 0, 0, 0); margin-top: -5px; right: 0px; top: 50%; }
div.sttip .popover .arrow { height: 0px; position: absolute; width: 0px; }
div.sttip .tooltip .popover-inner { background: rgba(0, 0, 0, 0.8); border-radius: 6px; box-shadow: rgba(0, 0, 0, 0.3) 0px 3px 7px; overflow: hidden; padding: 3px; width: 280px; }
div.sttip .video-container .popover-inner { min-width: 420px; width: auto; }
div.tooltip.video-container.ogl-mobile .popover-inner { min-width: unset; }
div.sttip .tooltip .popover-title { background-color: rgb(245, 245, 245); border-bottom: 1px solid rgb(238, 238, 238); border-radius: 3px 3px 0px 0px; line-height: 1; padding: 9px 15px; }
div.sttip .tooltip .popover-content { background-clip: padding-box; background-color: rgb(255, 255, 255); border-radius: 0px 0px 3px 3px; padding: 14px; }
div.sttip .popover-content p { margin-bottom: 0px; }
div.sttip .popover-content > div > ol, div.sttip .popover-content > div > ul { margin-block: 1em; }
div.sttip .close { color: rgb(0, 0, 0); float: right; font-size: 20px; font-weight: 700; line-height: 18px; opacity: 0.2; text-shadow: rgb(255, 255, 255) 0px 1px 0px; }
div.sttip .close:hover { color: rgb(0, 0, 0); cursor: pointer; opacity: 0.4; text-decoration: none; }
div.sttip button.close { appearance: none; background: rgba(0, 0, 0, 0); border: 0px; cursor: pointer; padding: 0px; }
div.sttip div.tooltip { bottom: auto; }
div.sttip .video-container .popover-content [data-iridize-id="content"] { height: inherit; }
:root { --font-family: "Oracle Sans",Arial,sans-serif; --coachmark-arrow-width: 97px; --coachmark-arrow-height: 48px; }
@font-face { font-display: swap; font-family: "Oracle Sans Italic"; font-style: italic; font-weight: 100 900; src: url("../font/OracleSans_It.woff2") format("woff2"); }
svg.sttip.stBrandElement { display: block; height: 100vh; left: 0px; pointer-events: none; position: fixed; top: 0px; width: 100vw; z-index: 2147483636; }
div.sttip div.tooltip div { margin: 0px; padding: 0px; }
div.sttip, div.sttip * { position: static; }
.sttip .dragger-tip-container { background-color: inherit; cursor: move; flex: 1 1 0%; height: 10px; text-align: center; }
div.sttip div.tooltip .popover-title { overflow: hidden; padding: 2px 2px 0px; border-bottom-width: medium !important; border-bottom-style: none !important; border-bottom-color: currentcolor !important; }
div.sttip div.tooltip .ir-field-container { margin-bottom: 5px; }
div.sttip div.tooltip .ir-field-container input[type="radio"] { vertical-align: middle; }
div.sttip div.tooltip .popover-inner { border: 1px solid rgb(212, 207, 202); box-shadow: rgba(0, 0, 0, 0.2) 0px 6px 12px; color: rgb(0, 0, 0); font-family: "Helvetica Neue", Helvetica, Arial, sans-serif; font-size: 16px; outline: none; text-shadow: none; transition: 0.3s cubic-bezier(0.25, 0.8, 0.25, 1); }
