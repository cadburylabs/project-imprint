.uif14 {
  height: 100%;
  & > body { height: 100%; padding: 0px; margin: 0px; }
}
.uif24 {
  position: fixed; top: 0px; z-index: 9998; display: flex; max-width: 438px; max-height: 100vh; overflow-y: hidden; pointer-events: none; align-items: flex-start !important;
  &.uif22 {
  top: 0px; flex-direction: column;
  & > [data-widget="GrowlMessage"] {
  margin: 8px 25px 0px;
  &:first-child { margin-top: 8px; }
  &:last-child { margin-bottom: 33px; }
}
}
  &.uif23 {
  bottom: 0px; flex-direction: column-reverse;
  & > [data-widget="GrowlMessage"] {
  margin: 0px 25px 8px;
  &:first-child { margin-bottom: 8px; }
  &:last-child { margin-top: 33px; }
}
}
  & > [data-widget="GrowlMessage"] { flex-shrink: 0; }
}
