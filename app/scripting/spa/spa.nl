.n-session-popup { font-size: 12px; }
.n-session-popup__content { padding: 20px 15px 10px; }
.n-session-popup__body { width: 250px; flex-grow: 1; }
.n-session-popup__image { width: 50px; height: 50px; margin-right: 15px; flex-shrink: 0; }
.n-session-popup__title { font-weight: bold; padding-bottom: 15px; }
.n-session-popup__button { align-self: flex-start; margin-left: 0px !important; margin-top: 15px !important; }
.n-session-popup__inactive-html-body > :not(.n-session-popup) { filter: blur(4px); }
.n-ssui-spa-create-confirmation { padding-top: var(--uif-refreshed-size-xl); width: 100%; word-break: break-word; }
.n-ssui-spa-create-confirmation .n-ssui-spa-create-confirmation__content-url-link { justify-content: center; }
.n-ssui-spa-create-detail { padding-top: var(--uif-refreshed-size-xl); }
.n-ssui-spa-create-detail .n-ssui-spa-create-detail__inputs-panel { width: 100%; padding-top: var(--uif-refreshed-size-s); }
.n-ssui-spa-create-detail .n-ssui-spa-create-detail__inputs-panel [data-widget="TextBox"] { width: 100%; }
.n-ssui-spa-create-detail .n-ssui-spa-create-detail__inputs-panel [data-widget="Dropdown"] { width: 100%; }
.n-ssui-spa-create-detail .n-ssui-spa-create-detail__inputs-panel [data-widget="TextArea"] { width: -webkit-fill-available; }
.n-ssui-spa-create-detail .n-ssui-spa-create-detail__inputs-panel .n-w-stack-panel { width: 100%; }
.n-ssui-spa-create-detail .n-ssui-spa-create-detail__inputs-panel .n-ssui-spa-create-detail__inputs-panel-url-panel { padding-top: var(--uif-refreshed-size-m); }
.n-ssui-spa-create-detail .n-ssui-spa-create-detail__inputs-panel .n-ssui-spa-create-detail__inputs-panel-url-panel .n-w-paragraph { width: auto; margin-left: 3px; margin-right: 5px; }
.n-ssui-spa-create-detail .n-ssui-spa-create-detail__inputs-panel .n-ssui-spa-create-detail__inputs-panel-url-panel .n-w-textbox { width: auto; margin-left: 0px; flex: 1 1 auto; }
.n-ssui-spa-create-detail .n-ssui-spa-create-detail__inputs-panel .n-ssui-spa-create-detail__inputs-panel-url-panel .n-ssui-spa-create-detail__inputs-panel-url-panel-info-panel .n-w-paragraph { width: auto; }
.n-ssui-spa-create-detail .n-ssui-spa-create-detail__inputs-panel .n-ssui-spa-create-detail__inputs-panel-file-cabinet-panel { padding-top: var(--uif-refreshed-size-m); }
.n-ssui-spa-list-grid-cell-status { width: 100%; }
.n-ssui-spa-create-main { padding: var(--uif-refreshed-size-3-xs) var(--uif-refreshed-size-m); }
.n-ssui-spa-create-main .n-ssui-spa-create-main__content-panel { width: 100%; }
.n-ssui-spa-create-main .n-ssui-spa-create-main__buttons-panel { padding-top: var(--uif-refreshed-size-xl); }
.n-ssui-spa-create-main .n-ssui-spa-create-main__error-component { fill: red; }
.n-ssui-spa-manage-layout { height: 100%; }
.n-ssui-spa-manage-error-component { fill: red; }
.n-ssui-spa-manage-warning-component { fill: rgb(255, 191, 2); }
.n-ssui-spa-manage-common-link { margin: 0px !important; }
.n-ssui-spa-manage-banner-padding { padding-left: 3px; }
.n-ssui-spa-manage-banner-margin { margin-right: 0px !important; }
.n-ssui-spa-manage-editable-field { margin-left: 0px !important; }
.n-ssui-spa-manage-editable-field-save-button { margin-left: 0px !important; }
.n-ssui-spa-manage-item-bubble { margin-bottom: 16px !important; margin-right: 10px !important; }
div.sttip, div.sttip a, div.sttip abbr, div.sttip acronym, div.sttip address, div.sttip article, div.sttip aside, div.sttip b, div.sttip big, div.sttip blockquote, div.sttip button, div.sttip canvas, div.sttip caption, div.sttip center, div.sttip cite, div.sttip code, div.sttip dd, div.sttip del, div.sttip details, div.sttip dfn, div.sttip div, div.sttip dl, div.sttip dt, div.sttip em, div.sttip fieldset, div.sttip footer, div.sttip form, div.sttip h1, div.sttip h2, div.sttip h3, div.sttip h4, div.sttip h5, div.sttip h6, div.sttip header, div.sttip hgroup, div.sttip i, div.sttip input, div.sttip ins, div.sttip kbd, div.sttip label, div.sttip legend, div.sttip li, div.sttip mark, div.sttip menu, div.sttip nav, div.sttip ol, div.sttip output, div.sttip p, div.sttip pre, div.sttip q, div.sttip ruby, div.sttip s, div.sttip samp, div.sttip section, div.sttip small, div.sttip span, div.sttip strike, div.sttip strong, div.sttip sub, div.sttip summary, div.sttip sup, div.sttip time, div.sttip tt, div.sttip u, div.sttip ul, div.sttip var { background: none; border: 0px; box-shadow: none; box-sizing: initial; color: inherit; cursor: auto; float: none; font: inherit; height: auto; margin: 0px; padding: 0px; text-indent: 0px; vertical-align: initial; width: auto; }
div.sttip applet, div.sttip audio, div.sttip embed, div.sttip iframe, div.sttip img, div.sttip object, div.sttip video { background: none; border: 0px; box-shadow: none; box-sizing: initial; color: inherit; cursor: auto; float: none; font: inherit; margin: 0px; padding: 0px; text-indent: 0px; vertical-align: initial; }
div.sttip span { cursor: inherit; }
div.sttip [dir="rtl"] { text-align: right; }
div.sttip article, div.sttip aside, div.sttip details, div.sttip figcaption, div.sttip figure, div.sttip footer, div.sttip header, div.sttip hgroup, div.sttip menu, div.sttip nav, div.sttip section { display: block; }
div.sttip { line-height: 1.1; }
div.sttip ol { list-style: inside decimal; }
div.sttip ul { list-style: inside disc; }
div.sttip li { list-style: inherit; }
div.sttip blockquote, div.sttip q { quotes: none; }
div.sttip blockquote::after, div.sttip blockquote::before, div.sttip q::after, div.sttip q::before { content: none; }
div.sttip table { border-collapse: collapse; border-spacing: 0px; }
div.sttip b, div.sttip strong { font-weight: 700; }
div.sttip em, div.sttip i { font-style: italic; }
div.sttip i::before { content: ""; }
div.sttip .clearfix { }
div.sttip .clearfix::after, div.sttip .clearfix::before { content: ""; display: table; }
div.sttip .clearfix::after { clear: both; }
div.sttip .hide-text { background-color: initial; border: 0px; color: rgba(0, 0, 0, 0); font: 0px / 0 a; text-shadow: none; }
div.sttip .input-block-level { box-sizing: border-box; display: block; min-height: 28px; width: 100%; }
div.sttip .btn { display: inline-block; background-color: rgb(245, 245, 245); background-image: -webkit-linear-gradient(top, rgb(255, 255, 255), rgb(230, 230, 230)); background-repeat: repeat-x; border-width: 1px; border-style: solid; border-color: rgb(204, 204, 204) rgb(204, 204, 204) rgb(179, 179, 179); border-image: initial; border-radius: 4px; box-shadow: rgba(255, 255, 255, 0.2) 0px 1px 0px inset, rgba(0, 0, 0, 0.05) 0px 1px 2px; color: rgb(51, 51, 51); cursor: pointer; font-size: 13px; line-height: 18px; margin-bottom: 0px; padding: 4px 10px; text-align: center; text-shadow: rgba(255, 255, 255, 0.75) 0px 1px 1px; vertical-align: middle; }
div.sttip .btn.active, div.sttip .btn.disabled, div.sttip .btn:active, div.sttip .btn:hover, div.sttip .btn[disabled] { background-color: rgb(230, 230, 230); }
div.sttip .btn.active, div.sttip .btn:active { }
div.sttip .btn:first-child { }
div.sttip .btn:hover { background-color: rgb(230, 230, 230); background-position: 0px -15px; color: rgb(51, 51, 51); text-decoration: none; transition: background-position 0.1s linear; }
div.sttip .btn:focus { outline: -webkit-focus-ring-color auto 5px; outline-offset: -2px; }
div.sttip .btn.active, div.sttip .btn:active { background-color: rgb(230, 230, 230); background-image: none; box-shadow: rgba(0, 0, 0, 0.15) 0px 2px 4px inset, rgba(0, 0, 0, 0.05) 0px 1px 2px; outline: 0px; }
div.sttip .btn.disabled, div.sttip .btn[disabled] { background-color: rgb(230, 230, 230); background-image: none; box-shadow: none; cursor: default; opacity: 0.65; }
div.sttip .btn-large { border-radius: 5px; font-size: 15px; line-height: normal; padding: 9px 14px; }
div.sttip .btn-large [class^="icon-"] { margin-top: 1px; }
div.sttip .btn-small { font-size: 11px; line-height: 16px; padding: 5px 9px; }
div.sttip .btn-small [class^="icon-"] { margin-top: -1px; }
div.sttip .btn-mini { font-size: 11px; line-height: 14px; padding: 2px 6px; }
div.sttip .btn-danger, div.sttip .btn-danger:hover, div.sttip .btn-info, div.sttip .btn-info:hover, div.sttip .btn-inverse, div.sttip .btn-inverse:hover, div.sttip .btn-primary, div.sttip .btn-primary:hover, div.sttip .btn-success, div.sttip .btn-success:hover, div.sttip .btn-warning, div.sttip .btn-warning:hover { color: rgb(255, 255, 255); text-shadow: rgba(0, 0, 0, 0.25) 0px -1px 0px; }
div.sttip .btn-danger.active, div.sttip .btn-info.active, div.sttip .btn-inverse.active, div.sttip .btn-primary.active, div.sttip .btn-success.active, div.sttip .btn-warning.active { color: rgba(255, 255, 255, 0.75); }
div.sttip .btn, div.sttip .btn-primary { border-color: rgba(0, 0, 0, 0.1) rgba(0, 0, 0, 0.1) rgba(0, 0, 0, 0.25); }
div.sttip .btn-primary { background-color: rgb(0, 116, 204); background-image: -webkit-linear-gradient(top, rgb(0, 136, 204), rgb(0, 85, 204)); background-repeat: repeat-x; }
